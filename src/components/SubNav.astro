---
// Sub Nav component matching the {component.category-tab} and top CTA specs in clay/DESIGN.md
---

<div class="sticky top-0 z-40 bg-canvas/85 backdrop-blur-md border-b border-hairline h-[52px] flex items-center justify-between px-6 select-none">
  <!-- Left Side: Category Name -->
  <div class="flex items-center gap-3 sm:gap-4">
    <h1 class="text-tagline font-bold text-ink leading-none font-display tracking-tight">
      Pinpoint
    </h1>
    <!-- Small divider -->
    <span class="hidden sm:inline w-[1px] h-4 bg-hairline"></span>
    <!-- Subtitle / Local area -->
    <span class="hidden sm:inline text-xs text-muted font-medium">Hyperlocal Hub</span>
    
    <!-- Points Tracker (Mint Filled Pill) -->
    <div class="flex items-center gap-1 bg-brand-mint text-primary-active dark:bg-brand-mint/15 dark:text-brand-mint px-3 py-1 rounded-pill text-[12px] font-semibold font-sans tracking-wide">
      <span id="user-points-display" class="font-bold">350</span> pts
    </div>
  </div>

  <!-- Right Side: Navigation Tabs and Primary CTA -->
  <div class="flex items-center gap-6">
    <!-- Inline Navigation Tabs in Clay's category-tab pill grammar -->
    <div class="hidden lg:flex items-center gap-2" id="subnav-tabs-container">
      <a href="/" class="text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150" data-route="/">Home</a>
      <a href="/feed" class="text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150" data-route="/feed">Active Issues</a>
      <a href="/hotspots" class="text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150" data-route="/hotspots">Hotspots</a>
      <a href="/impact" class="text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150" data-route="/impact">Impact</a>
      <a href="/leaderboard" class="text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150" data-route="/leaderboard">Leaderboard</a>
    </div>

    <!-- Report Issue CTA - Clay B2B near-black primary rounded button (rounded: 12px, height: 44px) -->
    <button 
      id="subnav-report-btn" 
      class="bg-primary hover:bg-primary-active text-on-primary font-sans text-button-utility font-semibold rounded-md px-5 h-11 flex items-center justify-center active-scale focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors cursor-pointer"
    >
      Report Issue
    </button>

    <!-- Theme Toggle Button -->
    <button 
      class="theme-toggle-btn w-10 h-10 rounded-md border border-hairline flex items-center justify-center cursor-pointer hover:bg-surface-card active-scale transition-colors text-ink focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
      title="Toggle Color Theme"
      aria-label="Toggle Color Theme"
    >
      <!-- Sun icon (visible in dark mode) -->
      <svg class="theme-toggle-sun-icon w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="5"></circle>
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 18.36l1.42-1.42M18.36 4.22l1.42-1.42"></path>
      </svg>
      <!-- Moon icon (visible in light mode) -->
      <svg class="theme-toggle-moon-icon w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- User Profile Avatar/Button (Clay Styled) -->
    <div id="subnav-auth-container" class="flex items-center gap-3">
      <!-- Dynamic Sign In button or Avatar circle will be rendered here -->
    </div>
  </div>
</div>

<script>
document.addEventListener('astro:page-load', () => {
  // Setup click handler to open the Report Modal
  const reportBtn = document.getElementById('subnav-report-btn');
  if (reportBtn) {
    reportBtn.addEventListener('click', () => {
      // Dispatch a custom event to open the report modal in index.astro
      window.dispatchEvent(new CustomEvent('pinpoint_open_report_modal'));
    });
  }

  // Handle active subnav pill tab highlights
  const tabLinks = document.querySelectorAll('#subnav-tabs-container a');
  const currentPath = window.location.pathname;
  
  tabLinks.forEach(link => {
    const route = link.getAttribute('data-route');
    // Basic exact match or prefix match logic
    if (currentPath === route || (route !== '/' && currentPath.startsWith(route))) {
      link.className = "active-tab bg-surface-card text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150";
    } else {
      link.className = "text-muted hover:text-ink px-4 py-1.5 rounded-pill text-caption font-semibold transition-colors duration-150";
    }
  });

  // Hook into localStorage stats updates
  function updateNavStats() {
    try {
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      const ptsDisp = document.getElementById('user-points-display');
      if (ptsDisp) ptsDisp.textContent = userStats.points;
    } catch (e) {
      console.error(e);
    }
  }

  // Dynamic Authentication state rendering
  function renderAuthState() {
    const container = document.getElementById('subnav-auth-container');
    if (!container) return;
    
    const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
    const loggedInUser = localStorage.getItem('pinpoint_logged_in_user');
    
    let initials = 'RV';
    let name = 'Ritvik Vedangi';
    
    if (loggedInUser) {
      try {
        const u = JSON.parse(loggedInUser);
        name = u.name;
        // Compute initials
        initials = u.name.split(' ').map((n: string) => n[0]).join('').toUpperCase().substring(0, 2);
      } catch (e) {
        console.error(e);
      }
    }
    
    // Check if user is logged in
    const isLoggedIn = localStorage.getItem('pinpoint_is_logged_in') === 'true';
    
    if (isLoggedIn) {
      container.innerHTML = `
        <div id="subnav-avatar-btn" class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold font-display cursor-pointer hover:opacity-90 active-scale border border-hairline" title="${name}">
          ${initials}
        </div>
      `;
      
      const avatarBtn = document.getElementById('subnav-avatar-btn');
      avatarBtn?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('pinpoint_open_profile_modal'));
      });
    } else {
      container.innerHTML = `
        <button id="subnav-signin-btn" class="bg-surface-card hover:bg-hairline text-ink border border-hairline text-caption font-bold rounded-md px-4 h-11 flex items-center justify-center active-scale transition-colors cursor-pointer">
          Sign In
        </button>
      `;
      
      const signInBtn = document.getElementById('subnav-signin-btn');
      signInBtn?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('pinpoint_open_auth_modal'));
      });
    }
  }

  // Theme Toggle Logic
  function updateThemeIcons(theme: string) {
    const sunIcons = document.querySelectorAll('.theme-toggle-sun-icon');
    const moonIcons = document.querySelectorAll('.theme-toggle-moon-icon');
    
    if (theme === 'dark') {
      sunIcons.forEach(i => i.classList.remove('hidden'));
      moonIcons.forEach(i => i.classList.add('hidden'));
    } else {
      sunIcons.forEach(i => i.classList.add('hidden'));
      moonIcons.forEach(i => i.classList.remove('hidden'));
    }
  }

  // Bind listener only to buttons inside SubNav
  const subnavThemeBtns = document.querySelectorAll('.sticky .theme-toggle-btn');
  subnavThemeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      if (newTheme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      localStorage.setItem('pinpoint_theme', newTheme);
      updateThemeIcons(newTheme);
      
      // Notify other tabs and components
      window.dispatchEvent(new StorageEvent('storage', {
        key: 'pinpoint_theme',
        newValue: newTheme
      }));
    });
  });

  // Sync state on load
  const initialTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  updateThemeIcons(initialTheme);

  // Listen to external theme updates (local storage cross-tab, or custom event)
  window.addEventListener('pinpoint_theme_changed', (e: any) => {
    if (e.detail && e.detail.theme) {
      updateThemeIcons(e.detail.theme);
    }
  });

  // Re-run theme application when view changes
  updateNavStats();
  renderAuthState();

  // Listen for stats and auth updates
  window.addEventListener('pinpoint_stats_changed', updateNavStats);
  window.addEventListener('pinpoint_auth_changed', () => {
    updateNavStats();
    renderAuthState();
  });
});
</script>
