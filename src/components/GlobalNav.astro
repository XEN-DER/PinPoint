---
// Global Nav component matching the {component.top-nav} spec in clay/DESIGN.md
---

<nav class="bg-canvas border-b border-hairline text-ink h-16 flex items-center justify-between px-6 select-none relative z-50 text-nav-link">
  <!-- Left Side: Logo only -->
  <div class="flex items-center gap-8">
    <!-- Pinpoint Logo -->
    <a href="#" class="flex items-center gap-2.5 hover:opacity-80 active-scale" id="nav-logo">
      <!-- Friendly clay-like circular marker icon -->
      <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
      </svg>
      <span class="text-lg font-bold tracking-[-0.5px] text-ink font-display">Pinpoint</span>
    </a>
  </div>

  <!-- Right Side: User Profile Indicator (Gamification Quick Stats in Clay style) -->
  <div class="flex items-center gap-3 sm:gap-4">
    <!-- Theme Toggle Button -->
    <button 
      class="theme-toggle-btn w-10 h-10 rounded-md border border-hairline flex items-center justify-center cursor-pointer hover:bg-surface-card active-scale transition-colors text-ink focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
      title="Toggle Color Theme"
      aria-label="Toggle Color Theme"
    >
      <!-- Sun icon (visible in dark mode) -->
      <svg class="theme-toggle-sun-icon w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="5"></circle>
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 18.36l1.42-1.42M18.36 4.22l1.42-1.42"></path>
      </svg>
      <!-- Moon icon (visible in light mode) -->
      <svg class="theme-toggle-moon-icon w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- Points Tracker (Mint Filled Pill) -->
    <div class="flex items-center gap-1 bg-brand-mint text-primary-active dark:bg-brand-mint/15 dark:text-brand-mint px-3 py-1 rounded-pill text-[12px] font-semibold font-sans tracking-wide">
      <span id="user-points-display" class="font-bold">350</span> pts
    </div>
    
    <!-- User Badge -->
    <div class="hidden sm:flex items-center gap-1.5" id="user-profile-badge">
      <span class="w-2.5 h-2.5 rounded-full bg-success"></span>
      <span class="text-body-strong hover:text-primary transition-colors duration-150 cursor-pointer text-sm font-semibold" id="user-level-name">Civic Scout</span>
    </div>
  </div>
</nav>

<script>
  // Hook into localStorage stats updates
  function updateNavStats() {
    try {
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      
      const ptsDisp = document.getElementById('user-points-display');
      const lvlDisp = document.getElementById('user-level-name');

      if (ptsDisp) ptsDisp.textContent = userStats.points;
      if (lvlDisp) lvlDisp.textContent = userStats.level;
    } catch (e) {
      console.error(e);
    }
  }

  // Theme Toggle Logic
  function updateThemeIcons(theme: string) {
    const sunIcons = document.querySelectorAll('.theme-toggle-sun-icon');
    const moonIcons = document.querySelectorAll('.theme-toggle-moon-icon');
    
    if (theme === 'dark') {
      sunIcons.forEach(i => i.classList.remove('hidden'));
      moonIcons.forEach(i => i.classList.add('hidden'));
    } else {
      sunIcons.forEach(i => i.classList.add('hidden'));
      moonIcons.forEach(i => i.classList.remove('hidden'));
    }
  }

  // Bind listener only to buttons inside GlobalNav
  const globalThemeBtns = document.querySelectorAll('nav .theme-toggle-btn');
  globalThemeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      if (newTheme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      localStorage.setItem('pinpoint_theme', newTheme);
      updateThemeIcons(newTheme);
      
      // Notify other tabs and components
      window.dispatchEvent(new StorageEvent('storage', {
        key: 'pinpoint_theme',
        newValue: newTheme
      }));
    });
  });

  // Sync state on load
  const initialTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  updateThemeIcons(initialTheme);

  // Listen to external theme updates (local storage cross-tab, or custom event)
  window.addEventListener('pinpoint_theme_changed', (e: any) => {
    if (e.detail && e.detail.theme) {
      updateThemeIcons(e.detail.theme);
    }
  });

  // Update on mount
  updateNavStats();

  // Listen for points updates from the dashboard
  window.addEventListener('pinpoint_stats_changed', updateNavStats);

  // Wire up GlobalNav profile badge to open the profile modal
  const profileBadge = document.getElementById('user-profile-badge');
  if (profileBadge) {
    profileBadge.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('pinpoint_open_profile_modal'));
    });
  }
</script>
