---
// Global Nav component matching the {component.top-nav} spec in clay/DESIGN.md
---

<nav class="bg-canvas border-b border-hairline text-ink h-16 flex items-center justify-between px-6 select-none relative z-50 text-nav-link">
  <!-- Left Side: Logo and Desktop Menu -->
  <div class="flex items-center gap-8 w-full md:w-auto">
    <!-- Pinpoint Logo -->
    <a href="#" class="flex items-center gap-2.5 hover:opacity-80 active-scale" id="nav-logo">
      <!-- Friendly clay-like circular marker icon -->
      <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
      </svg>
      <span class="text-lg font-bold tracking-[-0.5px] text-ink font-display">Pinpoint</span>
    </a>

    <!-- Desktop Navigation Links (Friendly Inter 14px 500) -->
    <div class="hidden md:flex items-center gap-6 text-muted font-medium">
      <a href="#feed-section" class="hover:text-ink transition-colors duration-150">Issues Feed</a>
      <a href="#analytics-section" class="hover:text-ink transition-colors duration-150">Impact Analytics</a>
      <a href="#hotspots-section" class="hover:text-ink transition-colors duration-150">Predictive Hotspots</a>
      <a href="#gamification-section" class="hover:text-ink transition-colors duration-150">Leaderboard</a>
    </div>
  </div>

  <!-- Mobile Hamburger (Centered Logo and Right Menu Trigger) -->
  <div class="md:hidden absolute inset-0 flex items-center justify-center pointer-events-none">
    <span class="text-base font-bold tracking-[-0.3px] text-ink font-display pointer-events-auto">Pinpoint</span>
  </div>
  
  <div class="md:hidden flex items-center z-50">
    <button id="mobile-menu-toggle" class="text-ink hover:opacity-80 p-2 pointer-events-auto active-scale" aria-label="Toggle Navigation">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Right Side: User Profile Indicator (Gamification Quick Stats in Clay style) -->
  <div class="hidden md:flex items-center gap-4">
    <!-- Points Tracker (Mint Filled Pill) -->
    <div class="flex items-center gap-1 bg-brand-mint text-primary-active px-3 py-1 rounded-pill text-[12px] font-semibold font-sans tracking-wide">
      <span id="user-points-display" class="font-bold">350</span> pts
    </div>
    
    <!-- User Badge -->
    <div class="flex items-center gap-1.5" id="user-profile-badge">
      <span class="w-2.5 h-2.5 rounded-full bg-success"></span>
      <span class="text-body-strong hover:text-primary transition-colors duration-150 cursor-pointer text-sm font-semibold" id="user-level-name">Civic Scout</span>
    </div>
  </div>
</nav>

<!-- Mobile Navigation Menu Overlay in Warm Cream -->
<div id="mobile-nav-menu" class="hidden fixed inset-0 top-16 bg-canvas text-ink z-40 flex-col px-6 py-8 gap-6 md:hidden border-t border-hairline">
  <a href="#feed-section" class="mobile-nav-link text-lg font-semibold border-b border-hairline-soft pb-3 hover:text-primary">Issues Feed</a>
  <a href="#analytics-section" class="mobile-nav-link text-lg font-semibold border-b border-hairline-soft pb-3 hover:text-primary">Impact Analytics</a>
  <a href="#hotspots-section" class="mobile-nav-link text-lg font-semibold border-b border-hairline-soft pb-3 hover:text-primary">Predictive Hotspots</a>
  <a href="#gamification-section" class="mobile-nav-link text-lg font-semibold border-b border-hairline-soft pb-3 hover:text-primary">Leaderboard & Badges</a>
  
  <!-- Mobile User Stats -->
  <div class="mt-auto flex flex-col gap-3 pt-6 border-t border-hairline-soft">
    <div class="flex justify-between text-sm text-muted">
      <span>Current Points</span>
      <span class="text-primary font-bold"><span id="user-points-display-mobile">350</span> pts</span>
    </div>
    <div class="flex justify-between text-sm text-muted">
      <span>Civic Level</span>
      <span class="text-ink font-semibold" id="user-level-name-mobile">Civic Scout</span>
    </div>
  </div>
</div>

<script>
  // Mobile menu toggle logic
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-nav-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  
  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      if (isOpen) {
        mobileMenu.classList.add('hidden');
        hamburgerIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      } else {
        mobileMenu.classList.remove('hidden');
        hamburgerIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      }
    });

    // Close mobile menu when clicking any link
    const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      });
    });
  }

  // Hook into localStorage stats updates
  function updateNavStats() {
    try {
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      
      const ptsDisp = document.getElementById('user-points-display');
      const ptsDispMob = document.getElementById('user-points-display-mobile');
      const lvlDisp = document.getElementById('user-level-name');
      const lvlDispMob = document.getElementById('user-level-name-mobile');

      if (ptsDisp) ptsDisp.textContent = userStats.points;
      if (ptsDispMob) ptsDispMob.textContent = userStats.points;
      if (lvlDisp) lvlDisp.textContent = userStats.level;
      if (lvlDispMob) lvlDispMob.textContent = userStats.level;
    } catch (e) {
      console.error(e);
    }
  }

  // Update on mount
  updateNavStats();

  // Listen for points updates from the dashboard
  window.addEventListener('pinpoint_stats_changed', updateNavStats);
</script>
