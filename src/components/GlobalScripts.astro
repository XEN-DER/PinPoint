  // Helper to convert file input to Base64 data URL
  function fileToBase64(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = error => reject(error);
    });
  }

  // Helper to calculate SLA timers
  function getSLATimerHtml(issue: any, textLight: boolean): string {
    const reportDateStr = issue.date;
    const currentSimulatedDateStr = '2026-06-24';
    
    let targetDays = 5; // Low severity
    if (issue.severity === 'High') targetDays = 2;
    else if (issue.severity === 'Medium') targetDays = 3;
    
    const d1 = new Date(reportDateStr);
    let d2 = new Date(currentSimulatedDateStr);
    
    if (issue.status === 'Resolved' && issue.resolvedDate) {
      d2 = new Date(issue.resolvedDate);
    }
    
    d1.setHours(12, 0, 0, 0);
    d2.setHours(12, 0, 0, 0);
    
    const diffTime = d2.getTime() - d1.getTime();
    const elapsedDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
    
    const isDisputed = issue.disputed === true;
    const isSlaComplied = elapsedDays <= targetDays;
    
    let badgeClass = '';
    let badgeText = '';
    
    if (issue.status === 'Resolved') {
      if (isDisputed) {
        badgeClass = textLight ? 'bg-red-500/30 text-white' : 'bg-red-50 text-red-700 border-red-200 border';
        badgeText = 'SLA Breached (Disputed)';
      } else if (isSlaComplied) {
        badgeClass = textLight ? 'bg-emerald-500/30 text-white' : 'bg-emerald-50 text-emerald-700 border-emerald-200 border';
        badgeText = 'Resolved within SLA';
      } else {
        badgeClass = textLight ? 'bg-red-500/30 text-white' : 'bg-red-50 text-red-700 border-red-200 border';
        badgeText = 'Resolved Late (SLA Breached)';
      }
    } else {
      if (isDisputed) {
        badgeClass = textLight ? 'bg-red-500/30 text-white animate-pulse' : 'bg-red-50 text-red-700 border-red-300 border animate-pulse';
        badgeText = `âš ï¸ Disputed Â· SLA BREACHED`;
      } else if (elapsedDays > targetDays) {
        const overDays = elapsedDays - targetDays;
        badgeClass = textLight ? 'bg-red-500/30 text-white animate-pulse' : 'bg-red-50 text-red-700 border-red-300 border animate-pulse';
        badgeText = `âš ï¸ SLA BREACHED by ${overDays} day${overDays > 1 ? 's' : ''}`;
      } else {
        const remainingDays = targetDays - elapsedDays;
        badgeClass = textLight ? 'bg-canvas/10 text-on-dark' : 'bg-canvas text-ink border-hairline border';
        if (remainingDays === 0) {
          badgeText = `SLA expires today`;
        } else {
          badgeText = `${remainingDays} day${remainingDays > 1 ? 's' : ''} remaining`;
        }
      }
    }
    
    return `<span class="text-[11px] font-bold px-3 py-1 rounded-pill ${badgeClass}">${badgeText}</span>`;
  }

