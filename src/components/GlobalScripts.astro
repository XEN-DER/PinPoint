  // Resolve Form Submit handler
  resolveForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const issueId = (document.getElementById('resolve-form-issue-id') as HTMLInputElement).value;
    const notes = (document.getElementById('resolve-form-notes') as HTMLTextAreaElement).value;
    const mediaVal = (document.getElementById('resolve-form-media') as HTMLSelectElement).value;
    const resolvedBy = (document.getElementById('resolve-form-by') as HTMLInputElement).value;
    const fileInput = document.getElementById('resolve-form-file-upload') as HTMLInputElement;
    
    let resolvedImageUrl = "/images/pothole_fixed_vadodara.png";
    if (fileInput && fileInput.files && fileInput.files.length > 0) {
      try {
        resolvedImageUrl = await fileToBase64(fileInput.files[0]);
      } catch (err) {
        console.error("Failed to read resolution file upload:", err);
      }
    } else {
      if (mediaVal === 'streetlight') resolvedImageUrl = "/images/streetlight_fixed_vadodara.png";
      if (mediaVal === 'water') resolvedImageUrl = "/images/water_fixed_vadodara.png";
      if (mediaVal === 'garbage') resolvedImageUrl = "/images/garbage_fixed_vadodara.png";
    }
    
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === issueId);
    if (issue) {
      issue.status = 'Resolved';
      issue.resolvedImageUrl = resolvedImageUrl;
      issue.resolvedNotes = notes;
      issue.resolvedBy = resolvedBy;
      issue.resolvedDate = new Date().toISOString().split('T')[0];
      
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      
      // Award points
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 30;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));
      
      showToast("Issue resolved and verified! +30 points awarded.");
    }
    
    closeResolveModal();
    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  });

