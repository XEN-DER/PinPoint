  // Upvote Action Handler
  (window as any).handleUpvote = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const upvoted = JSON.parse(localStorage.getItem('pinpoint_user_upvotes') || '[]');
    
    if (upvoted.includes(id)) {
      const index = upvoted.indexOf(id);
      upvoted.splice(index, 1);
      
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications = Math.max(0, issue.verifications - 1);
      
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points = Math.max(0, userStats.points - 15);
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvote removed.");
    } else {
      upvoted.push(id);
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications += 1;

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvoted issue. +15 Civic points!");
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

  // Verify Action Handler
  (window as any).handleVerify = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === id);
    if (issue) {
      issue.verifications += 1;
      
      if (issue.verifications >= 3 && issue.status === 'Open') {
        issue.status = 'In Progress';
        showToast("Crowd verification complete. Escalated to 'In Progress'!");
      } else {
        showToast("Verification logged. +15 Civic points!");
      }

      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

