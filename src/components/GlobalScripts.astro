  // Resolve Modal Helpers
  function openResolveModal(issueId: string) {
    resolveModal?.classList.remove('hidden');
    syncScrollLock();
    
    // Find target issue to set auto-selected media and title
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === issueId);
    
    const issueIdInput = document.getElementById('resolve-form-issue-id') as HTMLInputElement;
    if (issueIdInput) issueIdInput.value = issueId;
    
    const modalTitle = document.getElementById('resolve-modal-title');
    if (modalTitle && issue) {
      modalTitle.textContent = `Verify & Resolve: ${issue.title}`;
    }
    
    // Auto-select resolution proof media category
    const mediaSelect = document.getElementById('resolve-form-media') as HTMLSelectElement;
    if (mediaSelect && issue) {
      if (issue.category === 'Infrastructure') mediaSelect.value = 'pothole';
      else if (issue.category === 'Streetlight') mediaSelect.value = 'streetlight';
      else if (issue.category === 'Water Leakage') mediaSelect.value = 'water';
      else if (issue.category === 'Waste Management') mediaSelect.value = 'garbage';
    }

    const resolvedByInput = document.getElementById('resolve-form-by') as HTMLInputElement;
    if (resolvedByInput) {
      const isLoggedIn = localStorage.getItem('pinpoint_is_logged_in') === 'true';
      const loggedInUser = localStorage.getItem('pinpoint_logged_in_user');
      let name = "Ritvik Vedangi";
      if (isLoggedIn && loggedInUser) {
        try {
          name = JSON.parse(loggedInUser).name;
        } catch (e) {}
      }
      resolvedByInput.value = `${name} (Citizen Verification)`;
    }
  }

  function closeResolveModal() {
