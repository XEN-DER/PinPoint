---
// Interactive SVG Map component for Pinpoint localized to Vadodara, India (Bapod area)
---

<div class="relative w-full h-[360px] md:h-[450px] bg-canvas border border-hairline rounded-lg overflow-hidden select-none">
  <!-- Map Legend (Top Left) -->
  <div class="absolute top-4 left-4 bg-canvas/90 backdrop-blur-sm border border-hairline px-3.5 py-2.5 rounded-md z-10 flex flex-col gap-1.5 text-xs text-ink shadow-sm">
    <div class="font-bold text-[10px] uppercase tracking-wider text-muted mb-0.5">Status Legend</div>
    <div class="flex items-center gap-2">
      <span class="w-2.5 h-2.5 rounded-full bg-error border border-canvas"></span>
      <span>Open (Escalated)</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="w-2.5 h-2.5 rounded-full bg-warning border border-canvas"></span>
      <span>In Progress</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="w-2.5 h-2.5 rounded-full bg-success border border-canvas"></span>
      <span>Resolved</span>
    </div>
  </div>

  <!-- Neighborhood Indicator (Top Right) -->
  <div class="absolute top-4 right-4 bg-canvas/90 backdrop-blur-sm border border-hairline px-3 py-1.5 rounded-md z-10 text-xs text-ink shadow-sm">
    <span class="text-muted">Viewing: </span>
    <span id="active-neighborhood-label" class="font-bold">All Localities</span>
  </div>

  <!-- SVG Map Canvas -->
  <svg 
    id="pinpoint-svg-map"
    viewBox="0 0 600 400" 
    class="w-full h-full object-cover transition-colors duration-300"
    style="background-color: #fffaf0;"
  >
    <!-- Grid Pattern Background -->
    <defs>
      <pattern id="grid-pattern" width="20" height="20" patternUnits="userSpaceOnUse">
        <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#e5e5e5" stroke-width="0.5" stroke-opacity="0.6" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid-pattern)" />

    <!-- Geographical Elements -->
    <!-- Canal / Lake (Vadodara Local Feature in Riverside/Waghodia Road) -->
    <path 
      d="M -10,250 C 150,230 200,320 280,340 C 350,350 450,280 610,290 L 610,410 L -10,410 Z" 
      fill="#dcefe8" 
      opacity="0.9"
      stroke="#a4d4c5"
      stroke-width="1.5"
    />
    
    <!-- Bapod Garden / Public Park -->
    <rect x="420" y="40" width="120" height="80" rx="12" fill="#e2f3ee" stroke="#a4d4c5" stroke-width="1.5" opacity="0.95" />
    <text x="480" y="85" fill="#1a3a3a" font-size="11" font-weight="600" text-anchor="middle" font-family="system-ui">Bapod Garden</text>

    <!-- Neighborhood Boundaries (Polygons for Hover States) -->
    <!-- Bapod (Top Left - User's Locality) -->
    <polygon 
      id="poly-bapod" 
      points="0,0 300,0 280,180 120,200 0,160" 
      class="neighborhood-poly fill-transparent hover:fill-brand-peach/10 cursor-pointer transition-colors duration-200" 
      data-name="Bapod"
    />
    
    <!-- Ajwa Road (Top Right) -->
    <polygon 
      id="poly-ajwa" 
      points="300,0 600,0 600,180 380,220 280,180" 
      class="neighborhood-poly fill-transparent hover:fill-brand-mint/10 cursor-pointer transition-colors duration-200" 
      data-name="Ajwa Road"
    />
    
    <!-- Waghodia Road (Bottom Left) -->
    <polygon 
      id="poly-waghodia" 
      points="0,160 120,200 280,180 280,340 0,400" 
      class="neighborhood-poly fill-transparent hover:fill-brand-lavender/10 cursor-pointer transition-colors duration-200" 
      data-name="Waghodia Road"
    />
    
    <!-- Kishanwadi (Bottom Right) -->
    <polygon 
      id="poly-kishanwadi" 
      points="280,180 380,220 600,180 600,400 280,340" 
      class="neighborhood-poly fill-transparent hover:fill-brand-coral/10 cursor-pointer transition-colors duration-200" 
      data-name="Kishanwadi"
    />

    <!-- Neighborhood Division Lines -->
    <line x1="300" y1="0" x2="280" y2="180" stroke="#e5e5e5" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="280" y1="180" x2="600" y2="180" stroke="#e5e5e5" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="280" y1="180" x2="120" y2="200" stroke="#e5e5e5" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="120" y1="200" x2="0" y2="160" stroke="#e5e5e5" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="280" y1="180" x2="280" y2="340" stroke="#e5e5e5" stroke-width="1.5" stroke-dasharray="4,4" />

    <!-- Major Roads -->
    <!-- Ajwa-Waghodia Ring Road -->
    <path d="M 0,100 Q 300,110 600,90" fill="none" stroke="#fffaf0" stroke-width="6" opacity="0.9" />
    <path d="M 0,100 Q 300,110 600,90" fill="none" stroke="#e5e5e5" stroke-width="4" stroke-dasharray="5,3" />
    <text x="50" y="92" fill="#9a9a9a" font-size="8" font-weight="600" font-family="system-ui">Ajwa-Waghodia Ring Rd</text>
    
    <!-- Bapod Main Road -->
    <path d="M 120,0 L 120,400" fill="none" stroke="#fffaf0" stroke-width="6" opacity="0.9" />
    <path d="M 120,0 L 120,400" fill="none" stroke="#e5e5e5" stroke-width="4" stroke-dasharray="5,3" />
    <text x="114" y="320" fill="#9a9a9a" font-size="8" font-weight="600" font-family="system-ui" transform="rotate(-90,114,320)">Bapod Main Road</text>

    <!-- Local Map Text Labels -->
    <text x="150" y="60" fill="#0a0a0a" font-size="12" font-weight="600" opacity="0.25" font-family="system-ui">BAPOD</text>
    <text x="460" y="160" fill="#0a0a0a" font-size="12" font-weight="600" opacity="0.25" font-family="system-ui">AJWA ROAD</text>
    <text x="60" y="240" fill="#0a0a0a" font-size="12" font-weight="600" opacity="0.25" font-family="system-ui">WAGHODIA ROAD</text>
    <text x="420" y="270" fill="#0a0a0a" font-size="12" font-weight="600" opacity="0.25" font-family="system-ui">KISHANWADI</text>

    <!-- Pins Container -->
    <g id="map-pins-group"></g>
  </svg>
</div>

<script>
  // Neighborhood Selection Hover Logic
  const polys = document.querySelectorAll('.neighborhood-poly');
  const label = document.getElementById('active-neighborhood-label');

  polys.forEach(poly => {
    poly.addEventListener('mouseenter', () => {
      if (label) {
        label.textContent = poly.getAttribute('data-name');
      }
    });

    poly.addEventListener('mouseleave', () => {
      const selected = document.querySelector('.neighborhood-poly.selected-region');
      if (label) {
        label.textContent = selected ? selected.getAttribute('data-name') : 'All Localities';
      }
    });

    poly.addEventListener('click', () => {
      const name = poly.getAttribute('data-name');
      
      polys.forEach(p => p.classList.remove('selected-region', 'fill-black/5'));
      poly.classList.add('selected-region', 'fill-black/5');
      
      window.dispatchEvent(new CustomEvent('pinpoint_filter_locality', {
        detail: { locality: name }
      }));
    });
  });

  // Dynamic Pin Plotting Engine
  const pinsGroup = document.getElementById('map-pins-group');

  function renderPins() {
    if (!pinsGroup) return;
    pinsGroup.innerHTML = '';

    let issues = [];
    try {
      issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    } catch(e) {
      console.error(e);
      return;
    }

    issues.forEach(issue => {
      if (!issue.mapX || !issue.mapY) return;

      let hexColor = '#ef4444'; // Red for Open
      if (issue.status === 'In Progress') {
        hexColor = '#f59e0b'; // Orange
      } else if (issue.status === 'Resolved') {
        hexColor = '#22c55e'; // Green
      }

      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('class', 'map-pin cursor-pointer group');
      g.setAttribute('data-id', issue.id);
      g.setAttribute('transform', `translate(${issue.mapX}, ${issue.mapY})`);

      if (issue.status !== 'Resolved') {
        const pulse = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        pulse.setAttribute('r', '9');
        pulse.setAttribute('fill', hexColor);
        pulse.setAttribute('opacity', '0.35');
        
        const animate = document.createElementNS('http://www.w3.org/2000/svg', 'animate');
        animate.setAttribute('attributeName', 'r');
        animate.setAttribute('values', '5;14;5');
        animate.setAttribute('dur', '2s');
        animate.setAttribute('repeatCount', 'indefinite');
        pulse.appendChild(animate);

        const animateOpacity = document.createElementNS('http://www.w3.org/2000/svg', 'animate');
        animateOpacity.setAttribute('attributeName', 'opacity');
        animateOpacity.setAttribute('values', '0.35;0.05;0.35');
        animateOpacity.setAttribute('dur', '2s');
        animateOpacity.setAttribute('repeatCount', 'indefinite');
        pulse.appendChild(animateOpacity);

        g.appendChild(pulse);
      }

      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('r', '5.5');
      dot.setAttribute('fill', hexColor);
      dot.setAttribute('stroke', '#fffaf0');
      dot.setAttribute('stroke-width', '1.5');
      dot.setAttribute('class', 'transition-all duration-200 group-hover:scale-125');
      g.appendChild(dot);

      const tooltip = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      tooltip.setAttribute('class', 'hidden group-hover:block');
      tooltip.setAttribute('transform', 'translate(0, -14)');
      
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', '-60');
      rect.setAttribute('y', '-16');
      rect.setAttribute('width', '120');
      rect.setAttribute('height', '22');
      rect.setAttribute('rx', '6');
      rect.setAttribute('fill', '#0a0a0a');
      tooltip.appendChild(rect);

      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('fill', '#ffffff');
      text.setAttribute('font-size', '9');
      text.setAttribute('font-weight', '600');
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('y', '-2');
      text.setAttribute('font-family', 'system-ui');
      
      const title = issue.title.length > 18 ? issue.title.substring(0, 16) + '...' : issue.title;
      text.textContent = title;
      tooltip.appendChild(text);

      g.appendChild(tooltip);

      g.addEventListener('click', (e) => {
        e.stopPropagation();
        window.dispatchEvent(new CustomEvent('pinpoint_select_issue', {
          detail: { id: issue.id }
        }));
      });

      pinsGroup.appendChild(g);
    });
  }

  // Initial render
  renderPins();

  window.addEventListener('pinpoint_issues_updated', renderPins);

  window.addEventListener('pinpoint_highlight_pin', (e: any) => {
    const targetId = e.detail.id;
    const pins = document.querySelectorAll('.map-pin');
    
    pins.forEach((pin: any) => {
      const pinId = pin.getAttribute('data-id');
      const dot = pin.querySelector('circle:last-of-type');
      if (pinId === targetId) {
        dot.setAttribute('r', '8.5');
        dot.setAttribute('stroke', '#0a0a0a');
        dot.setAttribute('stroke-width', '2');
        pinsGroup?.appendChild(pin);
      } else {
        dot.setAttribute('r', '5.5');
        dot.setAttribute('stroke', '#fffaf0');
        dot.setAttribute('stroke-width', '1.5');
      }
    });
  });

  const mapSvg = document.getElementById('pinpoint-svg-map');
  if (mapSvg) {
    mapSvg.addEventListener('click', () => {
      polys.forEach(p => p.classList.remove('selected-region', 'fill-black/5'));
      if (label) label.textContent = 'All Localities';
      
      window.dispatchEvent(new CustomEvent('pinpoint_filter_locality', {
        detail: { locality: 'All' }
      }));
      window.dispatchEvent(new CustomEvent('pinpoint_clear_highlights'));
    });
  }
</script>

<style>
  .neighborhood-poly {
    outline: none;
  }
</style>
