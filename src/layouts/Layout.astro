---
import { ClientRouter } from 'astro:transitions';
import '../styles/app.css';
import GlobalNav from '../components/GlobalNav.astro';
import SubNav from '../components/SubNav.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
import GlobalScripts from '../components/GlobalScripts.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Pinpoint — Hyperlocal Civic Issue Reporting & Resolution',
	description = 'Empower your community. Report, track, and resolve hyperlocal community issues like potholes, water leaks, waste management, and streetlights.'
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<ClientRouter />
		
		<!-- Theme Initialization Script (Prevents flash) -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('pinpoint_theme') || 
											(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>

		<!-- Cross-tab theme synchronization listener -->
		<script>
			window.addEventListener('storage', (e) => {
				if (e.key === 'pinpoint_theme' && e.newValue) {
					const newTheme = e.newValue;
					if (newTheme === 'dark') {
						document.documentElement.classList.add('dark');
					} else {
						document.documentElement.classList.remove('dark');
					}
					// Dispatch local event for components to sync icons
					window.dispatchEvent(new CustomEvent('pinpoint_theme_changed', { detail: { theme: newTheme } }));
				}
			});
		</script>
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Icons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Google Fonts Inter substitute for SF Pro -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
		
		<!-- Leaflet Map API -->
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

		<meta name="generator" content={Astro.generator} />
	</head>
	<body class="h-full bg-canvas text-body text-[16px] leading-[1.55] font-sans antialiased flex flex-col relative">
		<GlobalNav />
		<SubNav />
		<div class="flex-grow pt-[104px]">
			<slot />
		</div>
		<Footer />
		<Modals />
		<GlobalScripts />
	</body>
</html>
