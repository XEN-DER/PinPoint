---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leaderboard - Pinpoint">
  <div class="max-w-4xl mx-auto px-6 pt-12 pb-4 animate-toast-slide-up">
    <h1 class="text-hero-display text-ink">Leaderboard</h1>
    <p class="text-body text-lg mt-2">Earn points and rank up by reporting and verifying issues.</p>
  </div>
    <section id="gamification-section" class="bg-canvas border-b border-hairline py-8 px-6 sm:px-12 scroll-mt-[52px]">
      <div class="max-w-[1280px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
          
          <!-- Left Column: Citizen Gamification Stats -->
          <div class="lg:col-span-5 flex flex-col justify-between">
            <div>
              <span class="text-primary text-caption-uppercase tracking-[1.5px] font-bold mb-3 block">CITIZEN EMPOWERMENT</span>
              <h2 class="text-display-md text-ink font-semibold mb-4 font-display tracking-tight">
                Your Civic Dashboard
              </h2>
              <p class="text-body-md text-muted mb-8 leading-relaxed">
                Earn points and unlock historic B2B badges by reporting real issues, verifying community posts, and following up on municipal actions.
              </p>
            </div>

            <!-- Citizen Profile Card (rounded-lg 16px) -->
            <div class="bg-surface-pearl border border-hairline p-6 rounded-lg">
              <div class="flex items-center gap-4 mb-6">
                <!-- Avatar circle -->
                <div id="profile-avatar" class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-lg font-display">
                  RV
                </div>
                <div>
                  <h4 id="profile-name" class="text-body-strong text-ink font-bold mb-0.5">Ritvik Vedangi</h4>
                  <p class="text-xs text-muted font-medium" id="profile-level-badge">Level 1: Civic Scout</p>
                </div>
                <!-- Points -->
                <div class="ml-auto text-right">
                  <div class="text-lead text-primary font-bold font-sans" id="profile-points">350</div>
                  <div class="text-[10px] uppercase tracking-wider text-muted font-mono font-bold">Civic Points</div>
                </div>
              </div>

              <!-- Next Level Progress Bar -->
              <div class="mb-6">
                <div class="flex justify-between text-xs text-ink mb-1.5">
                  <span class="font-bold">Level Progress</span>
                  <span class="text-muted font-semibold" id="level-progress-text">350 / 450 pts</span>
                </div>
                <div class="h-2.5 w-full bg-surface-card rounded-full overflow-hidden border border-divider-soft">
                  <div class="h-full bg-primary rounded-full transition-all duration-300" id="level-progress-bar" style="width: 77%"></div>
                </div>
              </div>

              <!-- Badges Grid (Premium visual chips) -->
              <div>
                <h5 class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Earned Badges</h5>
                <div class="flex flex-wrap gap-2.5" id="badges-container">
                  <!-- Badge 1 -->
                  <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
                    <span class="text-base">ðŸ•³ï¸</span>
                    <span class="font-bold text-ink">Pothole Patrol</span>
                  </div>
                  <!-- Badge 2 -->
                  <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
                    <span class="text-base">ðŸ”¦</span>
                    <span class="font-bold text-ink">Light Guardian</span>
                  </div>
                  <!-- Badge 3 (Locked) -->
                  <div class="flex items-center gap-1.5 bg-canvas/30 border border-hairline border-dashed px-3 py-1.5 rounded-md text-xs opacity-50 select-none">
                    <span class="text-base">ðŸ’§</span>
                    <span class="font-semibold text-muted">Water Guard (Locked)</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column: Locality Leaderboard -->
          <div class="lg:col-span-7 bg-surface-pearl border border-hairline p-8 rounded-lg flex flex-col justify-between">
            <div>
              <h3 class="text-caption-uppercase text-ink font-bold mb-6 tracking-wider">
                This Month's Top Contributors
              </h3>
              
              <div class="flex flex-col gap-3" id="leaderboard-list">
                <!-- Leaderboard entries are populated by javascript -->
              </div>
            </div>

            <!-- Gamification Rules Hint -->
            <div class="mt-6 border-t border-hairline pt-4 text-xs text-muted flex justify-between items-center">
              <span>Verify reports to earn +15 pts. Report an issue to earn +100 pts.</span>
              <span class="text-primary font-bold cursor-pointer hover:underline">Rules Handbook â†’</span>
            </div>
          </div>

        </div>
      </div>
    </section>
</Layout>
