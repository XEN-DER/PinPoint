      reportedBy: "Clara W.",
      imageUrl: "/images/pothole_vadodara.png"
    }
  ];

  // Initialize DB in localStorage if empty or if it uses the old SVG coordinates/images
  let storedIssues = localStorage.getItem('pinpoint_issues');
  if (storedIssues) {
    try {
      const parsed = JSON.parse(storedIssues);
      if (parsed.length > 0 && (parsed[0].hasOwnProperty('mapX') || parsed[0].imageUrl === '/images/pothole.png')) {
        localStorage.removeItem('pinpoint_issues');
      }
    } catch(e) {
      localStorage.removeItem('pinpoint_issues');
    }
  }

  if (!localStorage.getItem('pinpoint_issues')) {
    localStorage.setItem('pinpoint_issues', JSON.stringify(preseededIssues));
  }

  // Preseeded Leaderboard citizens
  const topCitizens = [
    { name: "Sarah Patel", points: 840, issues: 8, badge: "Civic Champion" },
    { name: "Marcus Shah", points: 710, issues: 6, badge: "Community Guardian" },
    { name: "Elena Amin", points: 520, issues: 4, badge: "Community Guardian" },
    { name: "You (Jane Doe)", points: 350, issues: 3, badge: "Civic Scout", isUser: true },
    { name: "David Parmar", points: 290, issues: 2, badge: "Civic Scout" }
  ];

  if (!localStorage.getItem('pinpoint_leaderboard')) {
    localStorage.setItem('pinpoint_leaderboard', JSON.stringify(topCitizens));
  }

  // User Stats initialization
  if (!localStorage.getItem('pinpoint_user_stats')) {
    localStorage.setItem('pinpoint_user_stats', JSON.stringify({ points: 350, level: "Civic Scout" }));
  }

  // Track upvoted issues by user
  if (!localStorage.getItem('pinpoint_user_upvotes')) {
    localStorage.setItem('pinpoint_user_upvotes', JSON.stringify([]));
  }

  // Main Feed DOM bindings
  const searchInput = document.getElementById('feed-search') as HTMLInputElement;
  const categoryFilter = document.getElementById('feed-category-filter') as HTMLSelectElement;
  const statusFilter = document.getElementById('feed-status-filter') as HTMLSelectElement;
  const issuesFeed = document.getElementById('issues-feed');
  const emptyState = document.getElementById('feed-empty-state');
  const activeLocalityTag = document.getElementById('active-locality-filter-tag');
  const activeLocalityName = document.getElementById('active-locality-name');
  const clearLocalityBtn = document.getElementById('clear-locality-filter');

  // Modal DOM bindings
  const reportModal = document.getElementById('report-issue-modal');
  const reportForm = document.getElementById('report-issue-form') as HTMLFormElement;
  const cancelModalBtn = document.getElementById('modal-cancel-btn');
  const closeModalBtn = document.getElementById('modal-close-btn');

  // AI Overlay DOM bindings
  const aiOverlay = document.getElementById('ai-scanning-overlay');
  const aiStatusText = document.getElementById('ai-scanning-status-text');
  const aiVision = document.getElementById('ai-metric-vision');
  const aiGeo = document.getElementById('ai-metric-geo');
  const aiSeverity = document.getElementById('ai-metric-severity');

  // Current states
  let currentLocalityFilter = 'All';

  // Leaflet Report Map Picker logic
  let reportMap: any = null;
  let reportMarker: any = null;

  const localityCenters: Record<string, [number, number]> = {
    'Bapod': [22.3100, 73.2210],
    'Ajwa Road': [22.3150, 73.2100],
    'Waghodia Road': [22.2980, 73.2200],
    'Kishanwadi': [22.3090, 73.2050]
  };

  function initReportMap() {
    if (typeof L === 'undefined') {
      setTimeout(initReportMap, 100);
      return;
    }

    if (reportMap) {
      setTimeout(() => {
        reportMap.invalidateSize();
      }, 100);
      return;
    }

    const defaultLat = 22.3090;
    const defaultLng = 73.2200;

    reportMap = L.map('report-map-picker', {
      zoomControl: true,
      dragging: true,
      touchZoom: true
    }).setView([defaultLat, defaultLng], 14);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(reportMap);

    const pickerIcon = L.divIcon({
      html: `
        <div class="relative flex items-center justify-center w-8 h-8">
          <span class="absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-40 animate-ping"></span>
          <div class="relative w-4.5 h-4.5 rounded-full bg-red-500 border-2 border-white shadow-md flex items-center justify-center">
            <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
          </div>
        </div>
      `,
      className: 'custom-picker-marker',
      iconSize: [32, 32],
      iconAnchor: [16, 16],
    });

    reportMarker = L.marker([defaultLat, defaultLng], {
      draggable: true,
      icon: pickerIcon
    }).addTo(reportMap);

    function updateCoords(lat: number, lng: number) {
      const formLat = document.getElementById('form-lat') as HTMLInputElement;
      const formLng = document.getElementById('form-lng') as HTMLInputElement;
      if (formLat) formLat.value = lat.toFixed(6);
      if (formLng) formLng.value = lng.toFixed(6);
      reportMarker.setLatLng([lat, lng]);
    }

    reportMarker.on('dragend', () => {
      const position = reportMarker.getLatLng();
      updateCoords(position.lat, position.lng);
    });

    reportMap.on('click', (e: any) => {
      updateCoords(e.latlng.lat, e.latlng.lng);
    });

    setTimeout(() => {
      reportMap.invalidateSize();
    }, 100);
  }

  document.getElementById('form-locality')?.addEventListener('change', (e: any) => {
    const selected = e.target.value;
    const center = localityCenters[selected];
    if (center && reportMap) {
      reportMap.setView(center, 15);
      reportMarker.setLatLng(center);
      const formLat = document.getElementById('form-lat') as HTMLInputElement;
      const formLng = document.getElementById('form-lng') as HTMLInputElement;
      if (formLat) formLat.value = center[0].toFixed(6);
      if (formLng) formLng.value = center[1].toFixed(6);
    }
  });

  // Modal show / hide functions
  function openReportModal() {
    reportModal?.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    initReportMap();
  }

  function closeReportModal() {
    reportModal?.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    reportForm.reset();
    if (reportMarker) {
      reportMarker.setLatLng([22.3090, 73.2200]);
    }
    const formLat = document.getElementById('form-lat') as HTMLInputElement;
    const formLng = document.getElementById('form-lng') as HTMLInputElement;
    if (formLat) formLat.value = '22.3090';
    if (formLng) formLng.value = '73.2200';
  }

  window.addEventListener('pinpoint_open_report_modal', openReportModal);
  document.getElementById('hero-report-btn')?.addEventListener('click', openReportModal);
  cancelModalBtn?.addEventListener('click', closeReportModal);
  closeModalBtn?.addEventListener('click', closeReportModal);

  // Close modal when clicking outside form
  reportModal?.addEventListener('click', (e) => {
    if (e.target === reportModal) {
      closeReportModal();
    }
  });

  // Handle Locality Filter Event from Map
  window.addEventListener('pinpoint_filter_locality', (e: any) => {
    currentLocalityFilter = e.detail.locality;
    
    if (currentLocalityFilter === 'All') {
      activeLocalityTag?.classList.add('hidden');
    } else {
      activeLocalityTag?.classList.remove('hidden');
      if (activeLocalityName) activeLocalityName.textContent = currentLocalityFilter;
    }
    renderFeed();
  });

  // Clear Locality Filter
  clearLocalityBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    currentLocalityFilter = 'All';
    activeLocalityTag?.classList.add('hidden');
    
    window.dispatchEvent(new CustomEvent('pinpoint_clear_highlights'));
    renderFeed();
  });

  // Rerender ticker and profile stats
  function updateStatsWidgets() {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const total = issues.length;
    const resolved = issues.filter((i: any) => i.status === 'Resolved').length;
    const active = total - resolved;
    const rate = total > 0 ? Math.round((resolved / total) * 100) : 0;

    const tRep = document.getElementById('ticker-reported');
    const tRes = document.getElementById('ticker-resolved');
    const tAct = document.getElementById('ticker-active');
    const tRate = document.getElementById('ticker-rate');

    if (tRep) tRep.textContent = total;
    if (tRes) tRes.textContent = resolved;
    if (tAct) tAct.textContent = active;
    if (tRate) tRate.textContent = `${rate}%`;

    const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
    
    const profPoints = document.getElementById('profile-points');
    if (profPoints) profPoints.textContent = userStats.points;

    let maxPoints = 450;
    if (userStats.points >= 600) {
      userStats.level = "Civic Champion";
      maxPoints = 1000;
    } else if (userStats.points >= 450) {
      userStats.level = "Community Guardian";
      maxPoints = 600;
    } else {
      userStats.level = "Civic Scout";
      maxPoints = 450;
    }
    
    localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

    const levelBadge = document.getElementById('profile-level-badge');
    if (levelBadge) levelBadge.textContent = userStats.level;

    const progText = document.getElementById('level-progress-text');
    if (progText) progText.textContent = `${userStats.points} / ${maxPoints} pts`;

    const progBar = document.getElementById('level-progress-bar');
    if (progBar) {
      const percentage = Math.min(100, Math.round((userStats.points / maxPoints) * 100));
      progBar.style.width = `${percentage}%`;
    }

    const badgesContainer = document.getElementById('badges-container');
    if (badgesContainer) {
      badgesContainer.innerHTML = '';
      
      // Pothole badge
      badgesContainer.innerHTML += `
        <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
          <span class="text-base">🕳️</span>
          <span class="font-bold text-ink">Pothole Patrol</span>
        </div>
      `;

      // Streetlight badge
      if (userStats.points >= 380) {
        badgesContainer.innerHTML += `
          <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
            <span class="text-base">🔦</span>
            <span class="font-bold text-ink">Light Guardian</span>
          </div>
        `;
      } else {
        badgesContainer.innerHTML += `
          <div class="flex items-center gap-1.5 bg-canvas/30 border border-hairline border-dashed px-3 py-1.5 rounded-md text-xs opacity-50 select-none">
            <span class="text-base">🔦</span>
            <span class="font-semibold text-muted">Light Guardian (Locked)</span>
          </div>
        `;
      }

      // Water badge
      if (userStats.points >= 450) {
        badgesContainer.innerHTML += `
          <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
            <span class="text-base">💧</span>
            <span class="font-bold text-ink">Aqua Guard</span>
          </div>
        `;
      } else {
        badgesContainer.innerHTML += `
          <div class="flex items-center gap-1.5 bg-canvas/30 border border-hairline border-dashed px-3 py-1.5 rounded-md text-xs opacity-50 select-none">
            <span class="text-base">💧</span>
            <span class="font-semibold text-muted">Water Guard (Locked)</span>
          </div>
        `;
      }
    }

    renderLeaderboard();
    window.dispatchEvent(new CustomEvent('pinpoint_stats_changed'));
  }

  // Render leaderboard list dynamically (Clay styled)
  function renderLeaderboard() {
    const list = document.getElementById('leaderboard-list');
    if (!list) return;
    list.innerHTML = '';

    const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
    const leaders = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');

    const userIndex = leaders.findIndex((l: any) => l.isUser === true);
    if (userIndex !== -1) {
      leaders[userIndex].points = userStats.points;
      leaders[userIndex].badge = userStats.level;
    }

    leaders.sort((a: any, b: any) => b.points - a.points);
    localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaders));

    leaders.forEach((c: any, index: number) => {
      const position = index + 1;
      const highlightClass = c.isUser ? 'bg-brand-mint border-primary/20' : 'bg-canvas border-hairline';
      const medal = position === 1 ? '🥇' : position === 2 ? '🥈' : position === 3 ? '🥉' : `${position}`;

      list.innerHTML += `
        <div class="flex items-center justify-between p-3.5 rounded-md transition-colors border ${highlightClass}">
          <div class="flex items-center gap-4">
            <span class="w-6 text-center text-sm font-bold font-sans">${medal}</span>
            <div>
              <div class="text-caption font-bold text-ink">${c.name}</div>
              <div class="text-[11px] text-muted font-medium">${c.badge}</div>
            </div>
          </div>
          <div class="text-right font-sans text-sm font-bold text-ink">
            ${c.points} <span class="text-[10px] text-muted font-normal">pts</span>
          </div>
        </div>
      `;
    });
  }

  // Toast notifier
  function showToast(message: string) {
    const toast = document.getElementById('toast-notification');
    const toastMsg = document.getElementById('toast-message');
    if (toast && toastMsg) {
      toastMsg.textContent = message;
      toast.classList.remove('hidden');
      
      setTimeout(() => {
        toast.classList.add('hidden');
      }, 3000);
    }
  }

  // Render Issues Feed in Clay's Saturated Card system
  function renderFeed() {
    if (!issuesFeed || !emptyState) return;
    issuesFeed.innerHTML = '';

    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const upvoted = JSON.parse(localStorage.getItem('pinpoint_user_upvotes') || '[]');

    const query = searchInput?.value.toLowerCase() || '';
    const cat = categoryFilter?.value || 'All';
    const status = statusFilter?.value || 'All';

    const filtered = issues.filter((issue: any) => {
      const matchQuery = issue.title.toLowerCase().includes(query) || 
                          issue.description.toLowerCase().includes(query) || 
                          issue.locality.toLowerCase().includes(query);
      const matchCat = cat === 'All' ? true : issue.category === cat;
      const matchStatus = status === 'All' ? true : issue.status === status;
      const matchLocality = currentLocalityFilter === 'All' ? true : issue.locality === currentLocalityFilter;

      return matchQuery && matchCat && matchStatus && matchLocality;
    });

    if (filtered.length === 0) {
      emptyState.classList.remove('hidden');
      emptyState.classList.add('flex');
    } else {
      emptyState.classList.add('hidden');
      emptyState.classList.remove('flex');
    }

    filtered.forEach((issue: any) => {
      // 1. Map Saturated Card background colors by Category (Clay spec)
      let cardBgClass = 'bg-surface-card text-ink border-hairline';
      let textLight = false;
      
      let severityBadgeColor = 'text-red-700 bg-red-100/50 border-red-300';
      let statusBadgeColor = 'text-amber-700 bg-amber-100/50 border-amber-300 border';

      if (issue.category === 'Infrastructure') {
        cardBgClass = 'bg-brand-peach text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Streetlight') {
        cardBgClass = 'bg-brand-ochre text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Water Leakage') {
        cardBgClass = 'bg-brand-lavender text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Waste Management') {
        cardBgClass = 'bg-brand-teal text-on-dark border-transparent';
        severityBadgeColor = 'bg-canvas/15 text-on-dark border-transparent';
        statusBadgeColor = 'bg-canvas/15 text-on-dark border-transparent';
        textLight = true;
      }

      if (issue.status === 'Resolved') {
        statusBadgeColor = textLight 
          ? 'bg-canvas/20 text-on-dark border-transparent' 
          : 'bg-success/20 text-success border-success/30 border';
      }

      const hasUpvoted = upvoted.includes(issue.id);
      const verifyText = issue.status === 'Open' ? `Verify (${issue.verifications})` : `Verified (${issue.verifications})`;
      
      // Secondary buttons over saturated backgrounds must be high-contrast white containers
      let upvoteBtnClass = '';
      let verifyBtnClass = '';
      let resolveBtnClass = '';

      if (textLight) {
        // Over dark teal card
        upvoteBtnClass = hasUpvoted 
          ? 'bg-canvas/30 text-on-dark border border-canvas/25' 
          : 'bg-canvas text-ink hover:bg-surface-card';
        verifyBtnClass = 'bg-canvas/20 hover:bg-canvas/30 text-on-dark border border-canvas/25';
        resolveBtnClass = 'bg-canvas text-ink hover:bg-surface-card';
      } else {
        // Over peach, lavender, ochre, or cream card
        upvoteBtnClass = hasUpvoted 
          ? 'bg-primary text-on-primary hover:bg-primary-active' 
          : 'bg-canvas text-ink hover:bg-surface-card border border-hairline';
        verifyBtnClass = 'bg-canvas hover:bg-surface-card text-ink border border-hairline';
        resolveBtnClass = 'bg-primary text-on-primary hover:bg-primary-active';
      }

      const upvoteBtnText = hasUpvoted ? 'Upvoted' : 'Upvote';

      const imageElement = issue.imageUrl 
        ? `<img src="${issue.imageUrl}" alt="${issue.title}" class="w-full h-48 object-cover rounded-md border border-hairline/20 shadow-product mb-5 hover:opacity-95 transition-opacity" />`
        : '';

      issuesFeed.innerHTML += `
        <div 
          class="border p-6 rounded-xl select-text transition-all duration-200 ${cardBgClass}" 
          id="feed-card-${issue.id}"
          data-id="${issue.id}"
        >
          <!-- Photo resting on surface with shadow -->
          ${imageElement}

          <!-- Header info -->
          <div class="flex items-center justify-between gap-4 mb-3 text-caption font-bold">
            <span class="${textLight ? 'text-on-dark-soft' : 'text-muted'}">${issue.category} · ${issue.locality}</span>
            <span class="${textLight ? 'text-on-dark-soft' : 'text-muted'} font-mono">${issue.date}</span>
          </div>

          <!-- Title -->
          <h3 class="text-title-md font-bold mb-2.5 leading-snug">
            ${issue.title}
          </h3>

          <!-- Description -->
          <p class="text-sm leading-relaxed mb-6 ${textLight ? 'text-on-dark-soft' : 'text-body'}">
            ${issue.description}
          </p>

          <!-- Badges & Controls Row -->
          <div class="flex flex-wrap items-center gap-3 border-t border-divider-soft pt-4 mt-4">
            <!-- Severity Badge -->
            <span class="text-[11px] font-bold px-3 py-1 rounded-pill ${severityBadgeColor}">
              ${issue.severity} Severity
            </span>

            <!-- Status Badge -->
            <span class="text-[11px] font-bold px-3 py-1 rounded-pill ${statusBadgeColor}">
              ${issue.status}
            </span>

            <span class="text-xs ${textLight ? 'text-on-dark-soft' : 'text-muted'} ml-1 font-medium">By ${issue.reportedBy}</span>

            <!-- Controls (Verify, Upvote, Resolve) -->
            <div class="flex items-center gap-2 ml-auto">
              <!-- Upvote -->
              <button 
                onclick="handleUpvote('${issue.id}')"
                class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${upvoteBtnClass}"
              >
                ${upvoteBtnText} (${issue.verifications})
              </button>

              <!-- Verify (Only for Open issues) -->
              ${issue.status === 'Open' ? `
                <button 
                  onclick="handleVerify('${issue.id}')"
                  class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${verifyBtnClass}"
                >
                  Verify
                </button>
              ` : ''}

              <!-- Simulated Authority: Mark as Resolved -->
              ${issue.status !== 'Resolved' ? `
                <button 
                  onclick="handleResolve('${issue.id}')"
                  class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${resolveBtnClass}"
                >
                  Resolve
                </button>
              ` : ''}
            </div>
          </div>
        </div>
      `;
    });

    // Add card click listeners for map focusing
    const cards = document.querySelectorAll('[id^="feed-card-"]');
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const id = card.getAttribute('data-id');
        window.dispatchEvent(new CustomEvent('pinpoint_highlight_pin', {
          detail: { id }
        }));
      });
    });
  }

  // Upvote Action Handler
  (window as any).handleUpvote = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const upvoted = JSON.parse(localStorage.getItem('pinpoint_user_upvotes') || '[]');
    
    if (upvoted.includes(id)) {
      const index = upvoted.indexOf(id);
      upvoted.splice(index, 1);
      
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications = Math.max(0, issue.verifications - 1);
      
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points = Math.max(0, userStats.points - 15);
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvote removed.");
    } else {
      upvoted.push(id);
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications += 1;

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvoted issue. +15 Civic points!");
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

  // Verify Action Handler
  (window as any).handleVerify = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === id);
    if (issue) {
      issue.verifications += 1;
      
      if (issue.verifications >= 3 && issue.status === 'Open') {
        issue.status = 'In Progress';
        showToast("Crowd verification complete. Escalated to 'In Progress'!");
      } else {
        showToast("Verification logged. +15 Civic points!");
      }

      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

  // Resolve Action Handler (Authority Simulation)
  (window as any).handleResolve = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === id);
    if (issue) {
      issue.status = 'Resolved';
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 30;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Issue resolved! +30 points awarded.");
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

  // Form Submit with AI Auto-Tagging simulation
  reportForm?.addEventListener('submit', (e) => {
    e.preventDefault();

    const title = (document.getElementById('form-title') as HTMLInputElement).value;
    const locality = (document.getElementById('form-locality') as HTMLSelectElement).value;
    const description = (document.getElementById('form-description') as HTMLTextAreaElement).value;
    const mediaSelection = (document.getElementById('form-media') as HTMLSelectElement).value;

    const latVal = parseFloat((document.getElementById('form-lat') as HTMLInputElement).value || '22.3090');
    const lngVal = parseFloat((document.getElementById('form-lng') as HTMLInputElement).value || '73.2200');

    closeReportModal();

    if (aiOverlay) {
      aiOverlay.classList.remove('hidden');
      aiOverlay.classList.add('flex');
    }

    const states = [
      { text: "Initializing AI Vision Analyzer...", v: "Activating...", g: "Pending...", s: "Pending..." },
      { text: "Scanning description for key infrastructure indicators...", v: "Media Loaded.", g: "Locality Locked.", s: "Pending..." },
      { text: `Verifying coordinates [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]...`, v: "Media Loaded.", g: `Locked [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]`, s: "Scanning Hazards..." },
      { text: "Analyzing severity hazard index...", v: "Media Verified.", g: `Locked [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]`, s: "Determining SLA Class..." },
      { text: "Finalizing civic report...", v: "Complete.", g: "Complete.", s: "Complete." }
    ];

    let currentStep = 0;
    
    const interval = setInterval(() => {
      currentStep++;
      if (currentStep < states.length) {
        if (aiStatusText) aiStatusText.textContent = states[currentStep].text;
        if (aiVision) aiVision.textContent = states[currentStep].v;
        if (aiGeo) aiGeo.textContent = states[currentStep].g;
        if (aiSeverity) aiSeverity.textContent = states[currentStep].s;
      } else {
        clearInterval(interval);
        finalizeAIReport();
      }
    }, 700);

    function finalizeAIReport() {
      aiOverlay?.classList.add('hidden');
      aiOverlay?.classList.remove('flex');

      let category = "Infrastructure";
      const descLower = description.toLowerCase() + " " + title.toLowerCase();
      if (descLower.includes("pothole") || descLower.includes("road") || descLower.includes("pavement") || descLower.includes("curb")) {
        category = "Infrastructure";
      } else if (descLower.includes("leak") || descLower.includes("water") || descLower.includes("pipe") || descLower.includes("drain")) {
        category = "Water Leakage";
      } else if (descLower.includes("light") || descLower.includes("lamp") || descLower.includes("dark") || descLower.includes("bulb")) {
        category = "Streetlight";
      } else if (descLower.includes("trash") || descLower.includes("garbage") || descLower.includes("bin") || descLower.includes("waste")) {
        category = "Waste Management";
      }

      let severity = "Medium";
      if (descLower.includes("danger") || descLower.includes("severe") || descLower.includes("accident") || descLower.includes("flooding") || descLower.includes("injury")) {
        severity = "High";
      } else if (descLower.includes("small") || descLower.includes("minor") || descLower.includes("cosmetic")) {
        severity = "Medium";
      }

      let imageUrl = "/images/pothole_vadodara.png";
      if (mediaSelection === 'streetlight') imageUrl = "/images/streetlight_vadodara.png";
      if (mediaSelection === 'water') imageUrl = "/images/water_vadodara.png";
      if (mediaSelection === 'garbage') imageUrl = "/images/garbage_vadodara.png";

      const newIssue = {
        id: "issue-" + Date.now(),
        title,
        description,
        category,
        severity,
        status: "Open",
        locality,
        verifications: 0,
        lat: latVal,
        lng: lngVal,
        date: new Date().toISOString().split('T')[0],
        reportedBy: "Jane Doe (You)",
        imageUrl
      };

      const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
      issues.unshift(newIssue);
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));

      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 100;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast(`AI analysis complete. Category: ${category} (${severity} Severity). Plotted on map! +100 Civic points!`);

      renderFeed();
      updateStatsWidgets();
      
      window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
    }
  });

  window.addEventListener('pinpoint_select_issue', (e: any) => {
    const id = e.detail.id;
    const card = document.getElementById(`feed-card-${id}`);
    
    if (card) {
      const allCards = document.querySelectorAll('[id^="feed-card-"]');
      allCards.forEach(c => c.classList.remove('border-primary', 'bg-primary/5'));

      card.classList.add('border-primary', 'bg-primary/5');
      card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });

  window.addEventListener('pinpoint_clear_highlights', () => {
    const allCards = document.querySelectorAll('[id^="feed-card-"]');
    allCards.forEach(c => c.classList.remove('border-primary', 'bg-primary/5'));
  });

  searchInput?.addEventListener('input', renderFeed);
  categoryFilter?.addEventListener('change', renderFeed);
  statusFilter?.addEventListener('change', renderFeed);

  renderFeed();
  updateStatsWidgets();
</script>

<style>
  /* Local animations */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes reverse-spin {
    to { transform: rotate(-360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  .animate-reverse-spin {
    animation: reverse-spin 1.5s linear infinite;
  }
  .animate-fade-in {
    animation: fadeIn 0.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  .animate-scale-up {
    animation: scaleUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes scaleUp {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-slide-up-fade {
    animation: slideUpFade 3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  @keyframes slideUpFade {
    0% { opacity: 0; transform: translate(-50%, 20px); }
    10% { opacity: 1; transform: translate(-50%, 0); }
    90% { opacity: 1; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -20px); }
  }
</style>
