  // Rerender ticker and profile stats
  function updateStatsWidgets() {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const total = issues.length;
    const resolved = issues.filter((i: any) => i.status === 'Resolved').length;
    const active = total - resolved;
    const rate = total > 0 ? Math.round((resolved / total) * 100) : 0;

    const tRep = document.getElementById('ticker-reported');
    const tRes = document.getElementById('ticker-resolved');
    const tAct = document.getElementById('ticker-active');
    const tRate = document.getElementById('ticker-rate');

    if (tRep) tRep.textContent = total;
    if (tRes) tRes.textContent = resolved;
    if (tAct) tAct.textContent = active;
    if (tRate) tRate.textContent = `${rate}%`;

    const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
    
    const profPoints = document.getElementById('profile-points');
    if (profPoints) profPoints.textContent = userStats.points;

    let maxPoints = 450;
    if (userStats.points >= 600) {
      userStats.level = "Civic Champion";
      maxPoints = 1000;
    } else if (userStats.points >= 450) {
      userStats.level = "Community Guardian";
      maxPoints = 600;
    } else {
      userStats.level = "Civic Scout";
      maxPoints = 450;
    }
    
    localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

    const levelBadge = document.getElementById('profile-level-badge');
    if (levelBadge) levelBadge.textContent = userStats.level;

    // Update user profile name and avatar initials dynamically
    const isLoggedIn = localStorage.getItem('pinpoint_is_logged_in') === 'true';
    const loggedInUser = localStorage.getItem('pinpoint_logged_in_user');
    let name = "Guest Citizen";
    let initials = "GC";
    
    if (isLoggedIn && loggedInUser) {
      try {
        const u = JSON.parse(loggedInUser);
        name = u.name;
        initials = u.name.split(' ').map((n: string) => n[0]).join('').toUpperCase().substring(0, 2);
      } catch (e) {
        console.error(e);
      }
    } else if (!isLoggedIn) {
      name = "Guest Citizen";
      initials = "GC";
    }

    const profName = document.getElementById('profile-name');
    const profAvatar = document.getElementById('profile-avatar');
    if (profName) profName.textContent = name;
    if (profAvatar) profAvatar.textContent = initials;

    const progText = document.getElementById('level-progress-text');
    if (progText) progText.textContent = `${userStats.points} / ${maxPoints} pts`;

    const progBar = document.getElementById('level-progress-bar');
    if (progBar) {
      const percentage = Math.min(100, Math.round((userStats.points / maxPoints) * 100));
      progBar.style.width = `${percentage}%`;
    }

    const badgesContainer = document.getElementById('badges-container');
    if (badgesContainer) {
      badgesContainer.innerHTML = '';
      
