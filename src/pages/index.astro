  function initReportMap() {
    if (typeof L === 'undefined') {
      setTimeout(initReportMap, 100);
      return;
    }

    if (reportMap) {
      setTimeout(() => {
        reportMap.invalidateSize();
      }, 100);
      return;
    }

    const defaultLat = 22.3090;
    const defaultLng = 73.2200;

    reportMap = L.map('report-map-picker', {
      zoomControl: true,
      dragging: true,
      touchZoom: true
    }).setView([defaultLat, defaultLng], 14);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(reportMap);

    const pickerIcon = L.divIcon({
      html: `
        <div class="relative flex items-center justify-center w-8 h-8">
          <span class="absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-40 animate-ping"></span>
          <div class="relative w-4.5 h-4.5 rounded-full bg-red-500 border-2 border-white shadow-md flex items-center justify-center">
            <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
          </div>
        </div>
      `,
      className: 'custom-picker-marker',
      iconSize: [32, 32],
      iconAnchor: [16, 16],
    });

    reportMarker = L.marker([defaultLat, defaultLng], {
      draggable: true,
      icon: pickerIcon
    }).addTo(reportMap);

    function updateCoords(lat: number, lng: number) {
      const formLat = document.getElementById('form-lat') as HTMLInputElement;
      const formLng = document.getElementById('form-lng') as HTMLInputElement;
      if (formLat) formLat.value = lat.toFixed(6);
      if (formLng) formLng.value = lng.toFixed(6);
      reportMarker.setLatLng([lat, lng]);
    }

    reportMarker.on('dragend', () => {
      const position = reportMarker.getLatLng();
      updateCoords(position.lat, position.lng);
    });

    reportMap.on('click', (e: any) => {
      updateCoords(e.latlng.lat, e.latlng.lng);
    });

    setTimeout(() => {
      reportMap.invalidateSize();
    }, 100);
  }

