---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pinpoint — Hyperlocal Civic Action Platform">
  <main class="flex-grow select-none bg-canvas">
    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 py-20 lg:py-28 flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Left text content -->
      <div class="flex-1 flex flex-col items-start gap-8 z-10 w-full animate-slide-up-fade">
        <h1 class="text-hero-display text-ink w-full pr-4 relative">
          Transform Your Neighborhood. <span class="text-muted">Together.</span>
        </h1>
        
        <p class="text-lead text-body-strong max-w-lg leading-relaxed">
          Pinpoint is an open, community-driven civic resolution platform. Report issues, verify repairs, and watch the impact unfold in real-time.
        </p>
      </div>
      
      <!-- Right Feature Graphic (Clean geometric composition) -->
      <div class="flex-1 w-full max-w-lg aspect-square bg-surface-card border border-hairline rounded-2xl p-6 relative flex flex-col justify-between overflow-hidden group shadow-sm animate-slide-up-fade stagger-1">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-lavender/5 to-transparent pointer-events-none"></div>
        <div class="flex justify-between items-start w-full relative z-10">
          <div class="bg-canvas border border-hairline px-4 py-2 rounded-full text-caption font-bold shadow-sm flex items-center gap-2 group-hover:-translate-y-1 transition-transform">
            <span class="w-2 h-2 rounded-full bg-brand-pink animate-pulse"></span>
            32 Active Reports
          </div>
        </div>
        <div class="relative z-10 bg-canvas border border-hairline p-5 rounded-xl shadow-sm transform translate-y-8 group-hover:translate-y-4 transition-transform duration-500 flex flex-col gap-3">
          <div class="flex justify-between items-center border-b border-divider-soft pb-3">
            <span class="text-caption font-bold text-ink">Bapod Water Line</span>
            <span class="text-[10px] font-mono font-bold bg-brand-teal text-white px-2 py-1 rounded">VERIFIED</span>
          </div>
          <div class="h-2 w-full bg-hairline rounded-full overflow-hidden">
            <div class="h-full bg-ink w-3/4"></div>
          </div>
          <span class="text-[10px] text-muted font-bold tracking-widest uppercase">75% Resolved</span>
        </div>
      </div>
    </section>

    <!-- Dashboard Grid -->
    <section class="max-w-6xl mx-auto px-6 py-12 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 animate-slide-up-fade stagger-2">
        <a href="/feed" class="bg-surface-card hover:bg-surface-strong border border-hairline rounded-lg p-6 flex flex-col gap-3 transition-transform active-scale group cursor-pointer block">
          <div class="w-12 h-12 bg-primary text-on-primary rounded-full flex items-center justify-center text-xl shadow-sm group-hover:scale-110 transition-transform">📝</div>
          <h3 class="text-lead font-bold text-ink">Active Issues</h3>
          <p class="text-caption text-muted">Browse, verify, and resolve issues reported in your neighborhood.</p>
        </a>
        
        <a href="/hotspots" class="bg-surface-card hover:bg-surface-strong border border-hairline rounded-lg p-6 flex flex-col gap-3 transition-transform active-scale group cursor-pointer block">
          <div class="w-12 h-12 bg-primary text-on-primary rounded-full flex items-center justify-center text-xl shadow-sm group-hover:scale-110 transition-transform">🗺️</div>
          <h3 class="text-lead font-bold text-ink">Hotspots Map</h3>
          <p class="text-caption text-muted">Visualize problem areas and neighborhood clusters in real-time.</p>
        </a>

        <a href="/impact" class="bg-surface-card hover:bg-surface-strong border border-hairline rounded-lg p-6 flex flex-col gap-3 transition-transform active-scale group cursor-pointer block">
          <div class="w-12 h-12 bg-primary text-on-primary rounded-full flex items-center justify-center text-xl shadow-sm group-hover:scale-110 transition-transform">📈</div>
          <h3 class="text-lead font-bold text-ink">Impact Analytics</h3>
          <p class="text-caption text-muted">See the real-time difference we are making in the community.</p>
        </a>

        <a href="/leaderboard" class="bg-surface-card hover:bg-surface-strong border border-hairline rounded-lg p-6 flex flex-col gap-3 transition-transform active-scale group cursor-pointer block">
          <div class="w-12 h-12 bg-primary text-on-primary rounded-full flex items-center justify-center text-xl shadow-sm group-hover:scale-110 transition-transform">🏆</div>
          <h3 class="text-lead font-bold text-ink">Leaderboard</h3>
          <p class="text-caption text-muted">Earn points and rank up by reporting and verifying issues.</p>
        </a>
      </div>
    </section>
  </main>
</Layout>
