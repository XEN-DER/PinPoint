    });
  });

  function updateSeverityRadioUI() {
    severityRadios.forEach((r: any) => {
      const label = r.closest('label');
      if (r.checked) {
        label?.classList.remove('border-hairline', 'bg-canvas');
        label?.classList.add('border-primary', 'bg-primary/5', 'ring-1', 'ring-primary');
      } else {
        label?.classList.remove('border-primary', 'bg-primary/5', 'ring-1', 'ring-primary');
        label?.classList.add('border-hairline', 'bg-canvas');
      }
    });
  }

