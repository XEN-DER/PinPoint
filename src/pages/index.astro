  // Form Submit with AI Auto-Tagging simulation
  reportForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title = (document.getElementById('form-title') as HTMLInputElement).value;
    const locality = (document.getElementById('form-locality') as HTMLSelectElement).value;
    const description = (document.getElementById('form-description') as HTMLTextAreaElement).value;
    const mediaSelection = (document.getElementById('form-media') as HTMLSelectElement).value;
    const fileInput = document.getElementById('form-file-upload') as HTMLInputElement;

    const latVal = parseFloat((document.getElementById('form-lat') as HTMLInputElement).value || '22.3090');
    const lngVal = parseFloat((document.getElementById('form-lng') as HTMLInputElement).value || '73.2200');

    const category = (document.getElementById('form-category') as HTMLSelectElement).value || "Infrastructure";
    const severityInput = document.querySelector('input[name="form-severity"]:checked') as HTMLInputElement;
    const severity = severityInput ? severityInput.value : "Medium";

    // Read the uploaded file if present
    let uploadedImageUrl = '';
    if (fileInput && fileInput.files && fileInput.files.length > 0) {
      try {
        uploadedImageUrl = await fileToBase64(fileInput.files[0]);
      } catch (err) {
        console.error("Failed to read file upload:", err);
      }
    }

    closeReportModal();

    if (aiOverlay) {
      aiOverlay.classList.remove('hidden');
      aiOverlay.classList.add('flex');
    }

    const states = [
      { text: "Initializing AI Vision Analyzer...", v: "Activating...", g: "Pending...", s: "Pending..." },
      { text: "Scanning description for key infrastructure indicators...", v: "Media Loaded.", g: "Locality Locked.", s: "Pending..." },
      { text: `Verifying coordinates [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]...`, v: "Media Loaded.", g: `Locked [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]`, s: "Scanning Hazards..." },
      { text: "Analyzing severity hazard index...", v: "Media Verified.", g: `Locked [${latVal.toFixed(4)}, ${lngVal.toFixed(4)}]`, s: "Determining SLA Class..." },
      { text: "Finalizing civic report...", v: "Complete.", g: "Complete.", s: "Complete." }
    ];

    let currentStep = 0;
    
    const interval = setInterval(() => {
      currentStep++;
      if (currentStep < states.length) {
        if (aiStatusText) aiStatusText.textContent = states[currentStep].text;
        if (aiVision) aiVision.textContent = states[currentStep].v;
        if (aiGeo) aiGeo.textContent = states[currentStep].g;
        if (aiSeverity) aiSeverity.textContent = states[currentStep].s;
      } else {
        clearInterval(interval);
        finalizeAIReport();
      }
    }, 700);

    function finalizeAIReport() {
      aiOverlay?.classList.add('hidden');
      aiOverlay?.classList.remove('flex');

      let imageUrl = "/images/pothole_vadodara.png";
      if (uploadedImageUrl) {
        imageUrl = uploadedImageUrl;
      } else {
        if (mediaSelection === 'streetlight') imageUrl = "/images/streetlight_vadodara.png";
        if (mediaSelection === 'water') imageUrl = "/images/water_vadodara.png";
        if (mediaSelection === 'garbage') imageUrl = "/images/garbage_vadodara.png";
      }

      const newIssue = {
        id: "issue-" + Date.now(),
        title,
        description,
        category,
        severity,
        status: "Open",
        locality,
        verifications: 0,
        lat: latVal,
        lng: lngVal,
        date: new Date().toISOString().split('T')[0],
        reportedBy: (() => {
          const isLoggedIn = localStorage.getItem('pinpoint_is_logged_in') === 'true';
          const loggedInUser = localStorage.getItem('pinpoint_logged_in_user');
          if (isLoggedIn && loggedInUser) {
            try {
              return JSON.parse(loggedInUser).name + " (You)";
            } catch (e) {}
          }
          return "Ritvik Vedangi (You)";
        })(),
        imageUrl
      };

      const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
      issues.unshift(newIssue);
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));

      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 100;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast(`AI analysis complete. Category: ${category} (${severity} Severity). Plotted on map! +100 Civic points!`);

      renderFeed();
      updateStatsWidgets();
      
      window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
    }
  });

