<script>
  // Helper to convert file input to Base64 data URL
  function fileToBase64(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = error => reject(error);
    });
  }

  // Helper to calculate SLA timers
  function getSLATimerHtml(issue: any, textLight: boolean): string {
    const reportDateStr = issue.date;
    const currentSimulatedDateStr = '2026-06-24';
    
    let targetDays = 5; // Low severity
    if (issue.severity === 'High') targetDays = 2;
    else if (issue.severity === 'Medium') targetDays = 3;
    
    const d1 = new Date(reportDateStr);
    let d2 = new Date(currentSimulatedDateStr);
    
    if (issue.status === 'Resolved' && issue.resolvedDate) {
      d2 = new Date(issue.resolvedDate);
    }
    
    d1.setHours(12, 0, 0, 0);
    d2.setHours(12, 0, 0, 0);
    
    const diffTime = d2.getTime() - d1.getTime();
    const elapsedDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
    
    const isDisputed = issue.disputed === true;
    const isSlaComplied = elapsedDays <= targetDays;
    
    let badgeClass = '';
    let badgeText = '';
    
    if (issue.status === 'Resolved') {
      if (isDisputed) {
        badgeClass = textLight ? 'bg-red-500/30 text-white' : 'bg-red-50 text-red-700 border-red-200 border';
        badgeText = 'SLA Breached (Disputed)';
      } else if (isSlaComplied) {
        badgeClass = textLight ? 'bg-emerald-500/30 text-white' : 'bg-emerald-50 text-emerald-700 border-emerald-200 border';
        badgeText = 'Resolved within SLA';
      } else {
        badgeClass = textLight ? 'bg-red-500/30 text-white' : 'bg-red-50 text-red-700 border-red-200 border';
        badgeText = 'Resolved Late (SLA Breached)';
      }
    } else {
      if (isDisputed) {
        badgeClass = textLight ? 'bg-red-500/30 text-white animate-pulse' : 'bg-red-50 text-red-700 border-red-300 border animate-pulse';
        badgeText = `⚠️ Disputed · SLA BREACHED`;
      } else if (elapsedDays > targetDays) {
        const overDays = elapsedDays - targetDays;
        badgeClass = textLight ? 'bg-red-500/30 text-white animate-pulse' : 'bg-red-50 text-red-700 border-red-300 border animate-pulse';
        badgeText = `⚠️ SLA BREACHED by ${overDays} day${overDays > 1 ? 's' : ''}`;
      } else {
        const remainingDays = targetDays - elapsedDays;
        badgeClass = textLight ? 'bg-canvas/10 text-on-dark' : 'bg-canvas text-ink border-hairline border';
        if (remainingDays === 0) {
          badgeText = `SLA expires today`;
        } else {
          badgeText = `${remainingDays} day${remainingDays > 1 ? 's' : ''} remaining`;
        }
      }
    }
    
    return `<span class="text-[11px] font-bold px-3 py-1 rounded-pill ${badgeClass}">${badgeText}</span>`;
  }

  // Preseeded users database
  const defaultUser = { name: "Ritvik Vedangi", email: "ritvik@example.com", password: "password123", points: 350, level: "Civic Scout" };
  if (!localStorage.getItem('pinpoint_users')) {
    localStorage.setItem('pinpoint_users', JSON.stringify([defaultUser]));
  }
  if (localStorage.getItem('pinpoint_is_logged_in') === null) {
    localStorage.setItem('pinpoint_is_logged_in', 'true');
    localStorage.setItem('pinpoint_logged_in_user', JSON.stringify(defaultUser));
  }

  // Dynamic issues database
  const preseededIssues = [
    {
      id: "issue-1",
      title: "Deep Pothole near Bapod Crossing",
      description: "A large, dangerous pothole is forcing two-wheelers and auto-rickshaws to swerve near the Bapod Crossing. Needs immediate patching.",
      category: "Infrastructure",
      severity: "High",
      status: "Open",
      locality: "Bapod",
      verifications: 2,
      lat: 22.3105,
      lng: 73.2215,
      date: "2026-06-21",
      reportedBy: "Sneha Patel",
      imageUrl: "/images/pothole_vadodara.png"
    },
    {
      id: "issue-2",
      title: "Broken Streetlight near Shanti Hospital",
      description: "The streetlight near Shanti Hospital on Waghodia Road has been completely out. The road section is pitch black at night, making it unsafe.",
      category: "Streetlight",
      severity: "Medium",
      status: "In Progress",
      locality: "Waghodia Road",
      verifications: 3,
      lat: 22.2985,
      lng: 73.2240,
      date: "2026-06-20",
      reportedBy: "Devendra Parmar",
      imageUrl: "/images/streetlight_vadodara.png"
    },
    {
      id: "issue-3",
      title: "Burst Water Main on Sayaji Park Road",
      description: "Drinking water is continuously leaking from the main pipe under the footpath, flooding Sayaji Park Road near Ajwa Road.",
      category: "Water Leakage",
      severity: "High",
      status: "Open",
      locality: "Ajwa Road",
      verifications: 1,
      lat: 22.3160,
      lng: 73.2185,
      date: "2026-06-22",
      reportedBy: "Esha Amin",
      imageUrl: "/images/water_vadodara.png"
    },
    {
      id: "issue-4",
      title: "Overflowing Garbage Bins near Kishanwadi Market",
      description: "Municipal trash bins near Kishanwadi Market are overflowing. Trash is scattering onto the road, creating an unhygienic block.",
      category: "Waste Management",
      severity: "Medium",
      status: "Resolved",
      locality: "Kishanwadi",
      verifications: 5,
      lat: 22.3130,
      lng: 73.2085,
      date: "2026-06-18",
      reportedBy: "Manish Shah",
      imageUrl: "/images/garbage_vadodara.png",
      resolvedImageUrl: "/images/garbage_fixed_vadodara.png",
      resolvedNotes: "Municipal waste team cleared the bins and swept the area clean.",
      resolvedBy: "VMC Waste Management",
      resolvedDate: "2026-06-19"
    },
    {
      id: "issue-5",
      title: "Damaged Road Divider near Bapod Talav",
      description: "The concrete road divider is damaged and displaced after a vehicle collision. Needs realignment to prevent traffic hazards.",
      category: "Infrastructure",
      severity: "High",
      status: "In Progress",
      locality: "Bapod",
      verifications: 4,
      lat: 22.3095,
      lng: 73.2205,
      date: "2026-06-19",
      reportedBy: "Kavita Verma",
      imageUrl: "/images/pothole_vadodara.png"
    }
  ];

  // Initialize DB in localStorage if empty or if it uses the old SVG coordinates/images/foreign names/lacks resolved details/Priya Sharma names
  let storedIssues = localStorage.getItem('pinpoint_issues');
  if (storedIssues) {
    try {
      const parsed = JSON.parse(storedIssues);
      const hasOldKeys = parsed.length > 0 && (parsed[0].hasOwnProperty('mapX') || parsed[0].imageUrl === '/images/pothole.png');
      const hasForeignNames = parsed.some((issue: any) => 
        issue.reportedBy === "Jane Doe" || 
        issue.reportedBy.includes("Jane Doe") ||
        issue.reportedBy.includes("Priya Sharma") ||
        issue.reportedBy === "Sarah Patel" || 
        issue.reportedBy === "David Parmar" || 
        issue.reportedBy === "Elena Amin" || 
        issue.reportedBy === "Marcus Shah" || 
        issue.reportedBy === "Clara W."
