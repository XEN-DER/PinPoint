---
import Layout from '../layouts/Layout.astro';
import SubNav from '../components/SubNav.astro';
import Map from '../components/Map.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Pinpoint — Hyperlocal Civic Action Platform">
  <!-- Nav Bar Stack -->
  <SubNav />

  <main class="flex-grow select-none bg-canvas">
    <!-- Hero Section (Alternating Light Tile matching {component.hero-band} in clay/DESIGN.md) -->
    <section id="analytics-section" class="bg-canvas border-b border-hairline py-20 px-6 sm:px-12 flex flex-col items-center text-center scroll-mt-[52px]">
      <div class="max-w-4xl mx-auto flex flex-col items-center">
        <!-- Badge Pill -->
        <span class="text-ink text-xs font-bold tracking-wider uppercase mb-4 bg-surface-card px-3.5 py-1.5 rounded-pill border border-hairline">
          🌱 Hyperlocal Action Hub
        </span>
        
        <!-- Headline in Plain Black style -->
        <h1 class="text-hero-display text-ink font-medium mb-6 select-text tracking-[-2.5px] leading-tight font-display">
          Pinpoint. Civic action, hand-crafted.
        </h1>
        
        <!-- Tagline -->
        <p class="text-lead text-body font-normal mb-8 max-w-2xl select-text leading-relaxed">
          Identify, report, and verify community issues. Connect with local municipal authorities in a transparent, warm, and collaborative ecosystem.
        </p>

        <!-- CTA Buttons (Clay rounded-md 12px style) -->
        <div class="flex flex-wrap justify-center gap-4 mb-16">
          <button 
            id="hero-report-btn" 
            class="bg-primary hover:bg-primary-active text-on-primary font-sans text-button-utility font-semibold rounded-md px-6 py-3 cursor-pointer active-scale shadow-sm focus:outline-none transition-colors"
          >
            Report an Issue
          </button>
          <a 
            href="#feed-section" 
            class="text-ink hover:bg-surface-card font-sans text-button-utility font-semibold border border-hairline rounded-md px-6 py-3 cursor-pointer active-scale transition-all flex items-center justify-center bg-transparent"
          >
            Explore Map & Feed
          </a>
        </div>

        <!-- Live Impact Stats Ticker (Clay-style horizontal list) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-12 w-full pt-12 border-t border-hairline">
          <div>
            <div class="text-display-md text-ink font-semibold font-display tracking-tight" id="ticker-reported">1,280</div>
            <div class="text-caption text-muted font-medium">Issues Reported</div>
          </div>
          <div>
            <div class="text-display-md text-primary font-semibold font-display tracking-tight" id="ticker-resolved">1,208</div>
            <div class="text-caption text-muted font-medium">Problems Resolved</div>
          </div>
          <div>
            <div class="text-display-md text-brand-coral font-semibold font-display tracking-tight" id="ticker-active">72</div>
            <div class="text-caption text-muted font-medium">Active Reports</div>
          </div>
          <div>
            <div class="text-display-md text-success font-semibold font-display tracking-tight" id="ticker-rate">94%</div>
            <div class="text-caption text-muted font-medium">Resolution Rate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map and Feed Grid Section (Soft Cream Canvas) -->
    <section id="feed-section" class="bg-canvas-parchment border-b border-hairline py-20 px-6 sm:px-12 scroll-mt-[52px]">
      <div class="max-w-[1280px] mx-auto">
        
        <!-- Section Header -->
        <div class="mb-12 text-center md:text-left">
          <span class="text-caption-uppercase text-muted tracking-[1.5px] font-semibold mb-2 block">LOCAL ACTION GRID</span>
          <h2 class="text-display-lg text-ink font-semibold mb-3 font-display tracking-tight">Hyperlocal Map & Feed</h2>
          <p class="text-body-md text-muted max-w-xl">
            Select a locality on the map to filter. Search keywords or filter by category to inspect active reports.
          </p>
        </div>

        <!-- Two Column Main Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          <!-- Left Column: Map Widget (lg:col-span-5) -->
          <div class="lg:col-span-5 lg:sticky lg:top-[72px]">
            <Map />
          </div>

          <!-- Right Column: Issues Feed and Filters (lg:col-span-7) -->
          <div class="lg:col-span-7 flex flex-col gap-6">
            <!-- Feed Search and Filters Panel (rounded-md 12px) -->
            <div class="bg-canvas border border-hairline p-5 rounded-md flex flex-col sm:flex-row gap-4 items-center justify-between">
              <!-- Search Input (Pill Shaped matching {component.search-input}) -->
              <div class="relative w-full sm:w-72">
                <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-muted">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </span>
                <input 
                  type="text" 
                  id="feed-search" 
                  placeholder="Search neighborhood or problem..." 
                  class="w-full h-11 bg-canvas border border-hairline rounded-pill pl-11 pr-5 text-body-md focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary placeholder-muted"
                />
              </div>

              <!-- Filter Controls Stack -->
              <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                <!-- Locality Tag display -->
                <span id="active-locality-filter-tag" class="hidden text-xs bg-brand-mint text-primary font-bold px-3 py-1 rounded-full flex items-center gap-1.5 animate-fade-in border border-hairline">
                  Locality: <span id="active-locality-name">All</span>
                  <button id="clear-locality-filter" class="hover:text-brand-coral cursor-pointer focus:outline-none font-bold text-sm ml-1" aria-label="Clear Locality Filter">×</button>
                </span>

                <!-- Category Dropdown Filter (Rounded Pill) -->
                <select 
                  id="feed-category-filter"
                  class="h-11 bg-canvas border border-hairline rounded-pill px-4 text-caption text-ink font-semibold focus:outline-none focus:border-primary cursor-pointer max-w-[160px]"
                >
                  <option value="All">All Categories</option>
                  <option value="Infrastructure">Infrastructure</option>
                  <option value="Water Leakage">Water Leakage</option>
                  <option value="Streetlight">Streetlights</option>
                  <option value="Waste Management">Waste Management</option>
                </select>

                <!-- Status Tabs -->
                <select 
                  id="feed-status-filter"
                  class="h-11 bg-canvas border border-hairline rounded-pill px-4 text-caption text-ink font-semibold focus:outline-none focus:border-primary cursor-pointer max-w-[140px]"
                >
                  <option value="All">All Statuses</option>
                  <option value="Open">Open</option>
                  <option value="In Progress">In Progress</option>
                  <option value="Resolved">Resolved</option>
                </select>
              </div>
            </div>

            <!-- Issues Feed Container -->
            <div id="issues-feed" class="flex flex-col gap-6">
              <!-- Issue Cards are injected here dynamically via client-side javascript -->
            </div>
            
            <!-- Empty State -->
            <div id="feed-empty-state" class="hidden bg-canvas border border-hairline p-12 rounded-lg text-center flex-col items-center justify-center">
              <svg class="w-10 h-10 text-muted mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <h3 class="text-body-strong text-ink mb-1">No matching reports found</h3>
              <p class="text-caption text-muted">Try adjusting your filters or search terms.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Analytics Section (Dark Teal/Navy Tile matching {colors.surface-dark}) -->
    <section id="hotspots-section" class="bg-surface-dark text-on-dark border-b border-hairline/10 py-20 px-6 sm:px-12 scroll-mt-[52px]">
      <div class="max-w-[1280px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- Left Content: Overview & Heatmap Stats -->
          <div class="lg:col-span-6">
            <span class="text-brand-mint text-caption-uppercase tracking-[1.5px] font-bold mb-3 block">AI PREDICTIVE INSIGHTS</span>
            <h2 class="text-display-md text-white font-medium mb-4 leading-tight font-display tracking-tight">
              Community Hotspots & Trends
            </h2>
            <p class="text-body-md text-on-dark-soft mb-8 leading-relaxed">
              Pinpoint applies historical analytical heuristics to locate community infrastructure distress zones. System algorithms predict recurring water failures and municipal garbage bottlenecks, advising local departments on resource allocation.
            </p>
            
            <!-- Locality breakdown progress bars -->
            <div class="flex flex-col gap-5">
              <div>
                <div class="flex justify-between text-caption text-white mb-1.5">
                  <span class="font-semibold">Ajwa Road (Water Line Failures)</span>
                  <span class="text-brand-pink font-semibold">Critical Threat</span>
                </div>
                <div class="h-2.5 w-full bg-surface-dark-elevated rounded-full overflow-hidden">
                  <div class="h-full bg-brand-pink rounded-full" style="width: 82%"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-caption text-white mb-1.5">
                  <span class="font-semibold">Bapod (Pothole Fissures)</span>
                  <span class="text-brand-ochre font-semibold">Medium Threat</span>
                </div>
                <div class="h-2.5 w-full bg-surface-dark-elevated rounded-full overflow-hidden">
                  <div class="h-full bg-brand-ochre rounded-full" style="width: 58%"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-caption text-white mb-1.5">
                  <span class="font-semibold">Waghodia Road (Waste Logistical Bottlenecks)</span>
                  <span class="text-brand-mint font-semibold">Under Control</span>
                </div>
                <div class="h-2.5 w-full bg-surface-dark-elevated rounded-full overflow-hidden">
                  <div class="h-full bg-brand-mint rounded-full" style="width: 25%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Content: Hotspots Alerts Widget (Dark Tile 2) -->
          <div class="lg:col-span-6 bg-surface-dark-elevated border border-hairline/10 p-8 rounded-lg">
            <h3 class="text-title-md text-white font-semibold mb-6 flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-coral animate-pulse" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              Predictive Alerts Feed
            </h3>
            
            <div class="flex flex-col gap-4" id="predictive-alerts">
              <!-- Alert Card 1 -->
              <div class="bg-surface-dark border border-hairline/10 p-5 rounded-md flex items-start gap-4">
                <span class="text-xl leading-none mt-1">⚠️</span>
                <div>
                  <h4 class="text-caption-strong text-white font-bold mb-1">Water mains recurrence in Ajwa Road</h4>
                  <p class="text-xs text-on-dark-soft leading-relaxed mb-3">
                    Water pipe fractures detected 3 times within 150m of Sayaji Park Road. High probability of underlying ground instability.
                  </p>
                  <span class="text-[10px] uppercase font-mono font-bold tracking-wider bg-brand-coral/20 text-brand-coral px-2.5 py-0.5 rounded">Action Suggested: Main Replacement</span>
                </div>
              </div>

              <!-- Alert Card 2 -->
              <div class="bg-surface-dark border border-hairline/10 p-5 rounded-md flex items-start gap-4">
                <span class="text-xl leading-none mt-1">📈</span>
                <div>
                  <h4 class="text-caption-strong text-white font-bold mb-1">Pothole hotspot cluster in Bapod</h4>
                  <p class="text-xs text-on-dark-soft leading-relaxed mb-3">
                    Road surface degradation accelerated along Bapod Main Road. Traffic density modeling predicts secondary fissures.
                  </p>
                  <span class="text-[10px] uppercase font-mono font-bold tracking-wider bg-brand-ochre/20 text-brand-ochre px-2.5 py-0.5 rounded">Action Suggested: Patching Scheduled</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Gamification Section (Warm Cream) -->
    <section id="gamification-section" class="bg-canvas border-b border-hairline py-20 px-6 sm:px-12 scroll-mt-[52px]">
      <div class="max-w-[1280px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
          
          <!-- Left Column: Citizen Gamification Stats -->
          <div class="lg:col-span-5 flex flex-col justify-between">
            <div>
              <span class="text-primary text-caption-uppercase tracking-[1.5px] font-bold mb-3 block">CITIZEN EMPOWERMENT</span>
              <h2 class="text-display-md text-ink font-semibold mb-4 font-display tracking-tight">
                Your Civic Dashboard
              </h2>
              <p class="text-body-md text-muted mb-8 leading-relaxed">
                Earn points and unlock historic B2B badges by reporting real issues, verifying community posts, and following up on municipal actions.
              </p>
            </div>

            <!-- Citizen Profile Card (rounded-lg 16px) -->
            <div class="bg-surface-pearl border border-hairline p-6 rounded-lg">
              <div class="flex items-center gap-4 mb-6">
                <!-- Avatar circle -->
                <div id="profile-avatar" class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-lg font-display">
                  RV
                </div>
                <div>
                  <h4 id="profile-name" class="text-body-strong text-ink font-bold mb-0.5">Ritvik Vedangi</h4>
                  <p class="text-xs text-muted font-medium" id="profile-level-badge">Level 1: Civic Scout</p>
                </div>
                <!-- Points -->
                <div class="ml-auto text-right">
                  <div class="text-lead text-primary font-bold font-sans" id="profile-points">350</div>
                  <div class="text-[10px] uppercase tracking-wider text-muted font-mono font-bold">Civic Points</div>
                </div>
              </div>

              <!-- Next Level Progress Bar -->
              <div class="mb-6">
                <div class="flex justify-between text-xs text-ink mb-1.5">
                  <span class="font-bold">Level Progress</span>
                  <span class="text-muted font-semibold" id="level-progress-text">350 / 450 pts</span>
                </div>
                <div class="h-2.5 w-full bg-surface-card rounded-full overflow-hidden border border-divider-soft">
                  <div class="h-full bg-primary rounded-full transition-all duration-300" id="level-progress-bar" style="width: 77%"></div>
                </div>
              </div>

              <!-- Badges Grid (Premium visual chips) -->
              <div>
                <h5 class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Earned Badges</h5>
                <div class="flex flex-wrap gap-2.5" id="badges-container">
                  <!-- Badge 1 -->
                  <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
                    <span class="text-base">🕳️</span>
                    <span class="font-bold text-ink">Pothole Patrol</span>
                  </div>
                  <!-- Badge 2 -->
                  <div class="flex items-center gap-1.5 bg-canvas border border-hairline px-3 py-1.5 rounded-md text-xs shadow-sm">
                    <span class="text-base">🔦</span>
                    <span class="font-bold text-ink">Light Guardian</span>
                  </div>
                  <!-- Badge 3 (Locked) -->
                  <div class="flex items-center gap-1.5 bg-canvas/30 border border-hairline border-dashed px-3 py-1.5 rounded-md text-xs opacity-50 select-none">
                    <span class="text-base">💧</span>
                    <span class="font-semibold text-muted">Water Guard (Locked)</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column: Locality Leaderboard -->
          <div class="lg:col-span-7 bg-surface-pearl border border-hairline p-8 rounded-lg flex flex-col justify-between">
            <div>
              <h3 class="text-caption-uppercase text-ink font-bold mb-6 tracking-wider">
                This Month's Top Contributors
              </h3>
              
              <div class="flex flex-col gap-3" id="leaderboard-list">
                <!-- Leaderboard entries are populated by javascript -->
              </div>
            </div>

            <!-- Gamification Rules Hint -->
            <div class="mt-6 border-t border-hairline pt-4 text-xs text-muted flex justify-between items-center">
              <span>Verify reports to earn +15 pts. Report an issue to earn +100 pts.</span>
              <span class="text-primary font-bold cursor-pointer hover:underline">Rules Handbook →</span>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- ---------------------------------------------------- -->
  <!-- MODAL: REPORT CIVIC ISSUE WIZARD -->
  <!-- ---------------------------------------------------- -->
  <div 
    id="report-issue-modal" 
    class="hidden fixed inset-0 bg-surface-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 select-none animate-fade-in"
  >
    <div 
      class="bg-canvas border border-hairline rounded-lg w-full max-w-lg overflow-hidden flex flex-col animate-scale-up"
      style="max-height: 90vh;"
    >
      <!-- Modal Header -->
      <div class="border-b border-hairline px-6 py-4 flex items-center justify-between">
        <h3 class="text-tagline font-bold text-ink font-display tracking-tight">Report New Issue</h3>
        <button id="modal-close-btn" class="text-muted hover:text-ink cursor-pointer text-xl font-bold focus:outline-none">&times;</button>
      </div>

      <!-- Modal Form Body (Rounded 12px Inputs) -->
      <form id="report-issue-form" class="p-6 flex flex-col gap-5 overflow-y-auto max-h-[calc(90vh-120px)] no-scrollbar">
        <!-- Issue Title -->
        <div class="flex flex-col gap-1.5">
          <label for="form-title" class="text-caption-strong text-ink font-bold">Short Title / Subject</label>
          <input 
            type="text" 
            id="form-title" 
            placeholder="e.g. Broken pavement slabs or leaking sewer pipe" 
            required 
            class="h-11 bg-canvas border border-hairline rounded-md px-3 text-[15px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-ink"
          />
        </div>

        <!-- Issue Locality -->
        <div class="flex flex-col gap-1.5">
          <label for="form-locality" class="text-caption-strong text-ink font-bold">Locality / Neighborhood</label>
          <select 
            id="form-locality" 
            required 
            class="h-11 bg-canvas border border-hairline rounded-md px-3 text-[15px] focus:outline-none focus:border-primary cursor-pointer text-ink"
          >
            <option value="" disabled selected>Select neighborhood</option>
            <option value="Bapod">Bapod</option>
            <option value="Ajwa Road">Ajwa Road</option>
            <option value="Waghodia Road">Waghodia Road</option>
            <option value="Kishanwadi">Kishanwadi</option>
          </select>
        </div>

        <!-- Map Location Picker -->
        <div class="flex flex-col gap-1.5">
          <label class="text-caption-strong text-ink font-bold">Pick Pin Location on Map</label>
          <div id="report-map-picker" class="w-full h-[180px] rounded-md border border-hairline overflow-hidden z-10" style="min-height: 180px;"></div>
          <input type="hidden" id="form-lat" value="22.3090" />
          <input type="hidden" id="form-lng" value="73.2200" />
          <span class="text-[11px] text-muted">Click the map or drag the marker to specify the exact issue location.</span>
        </div>

        <!-- Description -->
        <div class="flex flex-col gap-1.5">
          <label for="form-description" class="text-caption-strong text-ink font-bold">Detailed Description</label>
          <textarea 
            id="form-description" 
            rows="3" 
            placeholder="Please detail the location specifics, safety hazards, and any relevant context for the AI scan..." 
            required 
            class="bg-canvas border border-hairline rounded-md p-3 text-[15px] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-ink resize-none"
          ></textarea>
        </div>

        <!-- AI Copilot Scanner Block -->
        <div id="ai-copilot-widget" class="bg-surface-card border border-hairline rounded-md p-4 flex flex-col gap-3">
          <div class="flex items-center justify-between border-b border-hairline pb-2.5">
            <div class="flex items-center gap-2">
              <span class="text-lg">✨</span>
              <span class="text-caption-strong text-ink font-bold">AI Copilot Scanner</span>
            </div>
            <span id="ai-copilot-status" class="text-[10px] uppercase font-bold tracking-wider text-muted">Awaiting Input...</span>
          </div>
          <div class="flex items-center gap-3 py-1">
            <div id="ai-copilot-spinner" class="hidden w-4.5 h-4.5 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
            <div id="ai-copilot-result" class="text-xs text-muted leading-relaxed font-normal">
              Type a description or upload a photo to activate the live copilot suggestions.
            </div>
          </div>
        </div>

        <!-- Issue Category (Auto-filled by AI) -->
        <div class="flex flex-col gap-1.5">
          <label for="form-category" class="text-caption-strong text-ink font-bold flex items-center justify-between">
            <span>Category</span>
            <span class="text-[10px] text-primary bg-primary/10 px-1.5 py-0.5 rounded-full font-bold font-mono">AI Classifiable</span>
          </label>
          <select 
            id="form-category" 
            required 
            class="h-11 bg-canvas border border-hairline rounded-md px-3 text-[15px] focus:outline-none focus:border-primary cursor-pointer text-ink font-semibold"
          >
            <option value="Infrastructure">Infrastructure</option>
            <option value="Water Leakage">Water Leakage</option>
            <option value="Streetlight">Streetlights</option>
            <option value="Waste Management">Waste Management</option>
          </select>
        </div>

        <!-- Severity Hazard Index (Auto-filled by AI) -->
        <div class="flex flex-col gap-1.5">
          <label class="text-caption-strong text-ink font-bold flex items-center justify-between">
            <span>Severity Hazard Index</span>
            <span class="text-[10px] text-primary bg-primary/10 px-1.5 py-0.5 rounded-full font-bold font-mono">AI Classifiable</span>
          </label>
          <div class="flex gap-3">
            <label class="flex-1 flex items-center justify-center h-11 bg-canvas border border-hairline rounded-md cursor-pointer select-none text-xs font-bold text-ink hover:bg-surface-card transition-all">
              <input type="radio" name="form-severity" value="Low" class="sr-only" />
              <span>Low</span>
            </label>
            <label class="flex-1 flex items-center justify-center h-11 bg-canvas border border-hairline rounded-md cursor-pointer select-none text-xs font-bold text-ink hover:bg-surface-card transition-all border-primary bg-primary/5 ring-1 ring-primary">
              <input type="radio" name="form-severity" value="Medium" checked class="sr-only" />
              <span>Medium</span>
            </label>
            <label class="flex-1 flex items-center justify-center h-11 bg-canvas border border-hairline rounded-md cursor-pointer select-none text-xs font-bold text-ink hover:bg-surface-card transition-all">
              <input type="radio" name="form-severity" value="High" class="sr-only" />
              <span>High</span>
            </label>
          </div>
        </div>

        <!-- Attached Media -->
        <div class="flex flex-col gap-2">
          <label class="text-caption-strong text-ink font-bold">Attach Photo Evidence</label>
          
          <!-- File Input for Real Upload -->
          <div class="flex flex-col gap-1">
            <input 
              type="file" 
              id="form-file-upload" 
              accept="image/*"
              class="block w-full text-xs text-muted
                file:mr-4 file:py-2 file:px-4
                file:rounded-md file:border-0
                file:text-xs file:font-semibold
                file:bg-primary file:text-on-primary
                hover:file:bg-primary-active
                cursor-pointer"
            />
            <span class="text-[11px] text-muted">Upload a real photo from your device.</span>
          </div>

