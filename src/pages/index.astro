      const name = (document.getElementById('auth-name') as HTMLInputElement).value;
      
      // Check if user already exists
      if (users.some((u: any) => u.email === email)) {
        showToast("An account with this email already exists!");
        return;
      }
      
      const newUser = {
        name,
        email,
        password,
        points: 350,
        level: "Civic Scout"
      };
      
      users.push(newUser);
      localStorage.setItem('pinpoint_users', JSON.stringify(users));
      
      // Log in the new user
      localStorage.setItem('pinpoint_is_logged_in', 'true');
      localStorage.setItem('pinpoint_logged_in_user', JSON.stringify(newUser));
      localStorage.setItem('pinpoint_user_stats', JSON.stringify({ points: 350, level: "Civic Scout" }));
      
      // Add or update entry in leaderboard
      let leaderboard = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');
      const userIndex = leaderboard.findIndex((l: any) => l.isUser === true);
      if (userIndex !== -1) {
        leaderboard[userIndex].name = `You (${name})`;
        leaderboard[userIndex].points = 350;
        leaderboard[userIndex].badge = "Civic Scout";
      } else {
        leaderboard.push({ name: `You (${name})`, points: 350, issues: 3, badge: "Civic Scout", isUser: true });
      }
      localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaderboard));
      
      showToast(`Welcome ${name}! Account created and signed in.`);
    } else {
      // Login mode
      const user = users.find((u: any) => u.email === email && u.password === password);
      
      // Fallback for default seed user (Ritvik Vedangi)
      const defaultUser = { name: "Ritvik Vedangi", email: "ritvik@example.com", password: "password123", points: 350, level: "Civic Scout" };
      
      if (email === "ritvik@example.com" && password === "password123") {
        localStorage.setItem('pinpoint_is_logged_in', 'true');
        localStorage.setItem('pinpoint_logged_in_user', JSON.stringify(defaultUser));
        localStorage.setItem('pinpoint_user_stats', JSON.stringify({ points: defaultUser.points, level: defaultUser.level }));
        
        let leaderboard = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');
        const userIndex = leaderboard.findIndex((l: any) => l.isUser === true);
        if (userIndex !== -1) {
          leaderboard[userIndex].name = `You (${defaultUser.name})`;
        }
        localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaderboard));
        
        showToast("Signed in successfully as Ritvik Vedangi!");
      } else if (user) {
        localStorage.setItem('pinpoint_is_logged_in', 'true');
        localStorage.setItem('pinpoint_logged_in_user', JSON.stringify(user));
        localStorage.setItem('pinpoint_user_stats', JSON.stringify({ points: user.points, level: user.level }));
        
        let leaderboard = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');
        const userIndex = leaderboard.findIndex((l: any) => l.isUser === true);
        if (userIndex !== -1) {
          leaderboard[userIndex].name = `You (${user.name})`;
          leaderboard[userIndex].points = user.points;
          leaderboard[userIndex].badge = user.level;
        }
        localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaderboard));
        
        showToast(`Signed in successfully as ${user.name}!`);
      } else {
        showToast("Invalid email or password!");
        return;
      }
    }
    
    closeAuthModal();
    
    // Dispatch events to refresh navbar and components
    window.dispatchEvent(new CustomEvent('pinpoint_auth_changed'));
    renderLeaderboard();
    updateStatsWidgets();
  });

  // Logout logic
  logoutBtn?.addEventListener('click', () => {
    // Save current points back to the user database in localStorage before logging out
    const isLoggedIn = localStorage.getItem('pinpoint_is_logged_in') === 'true';
    const loggedInUser = localStorage.getItem('pinpoint_logged_in_user');
    if (isLoggedIn && loggedInUser) {
      try {
        const u = JSON.parse(loggedInUser);
        const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
        let users = JSON.parse(localStorage.getItem('pinpoint_users') || '[]');
        const userIndex = users.findIndex((usr: any) => usr.email === u.email);
        if (userIndex !== -1) {
          users[userIndex].points = userStats.points;
          users[userIndex].level = userStats.level;
          localStorage.setItem('pinpoint_users', JSON.stringify(users));
        }
      } catch (e) {
        console.error(e);
      }
    }

    localStorage.setItem('pinpoint_is_logged_in', 'false');
    localStorage.removeItem('pinpoint_logged_in_user');
    // Set guest user stats
    localStorage.setItem('pinpoint_user_stats', JSON.stringify({ points: 350, level: "Civic Scout" }));
    
    let leaderboard = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');
    const userIndex = leaderboard.findIndex((l: any) => l.isUser === true);
    if (userIndex !== -1) {
      leaderboard[userIndex].name = "You (Guest Citizen)";
      leaderboard[userIndex].points = 350;
      leaderboard[userIndex].badge = "Civic Scout";
    }
    localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaderboard));
    
    showToast("Signed out successfully.");
    closeProfileModal();
    
    // Dispatch events to refresh navbar and components
    window.dispatchEvent(new CustomEvent('pinpoint_auth_changed'));
    renderLeaderboard();
    updateStatsWidgets();
  });

  renderFeed();
  updateStatsWidgets();
</script>

<style>
  /* Local animations */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes reverse-spin {
    to { transform: rotate(-360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  .animate-reverse-spin {
    animation: reverse-spin 1.5s linear infinite;
  }
  .animate-fade-in {
    animation: fadeIn 0.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  .animate-scale-up {
    animation: scaleUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes scaleUp {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-slide-up-fade {
    animation: slideUpFade 3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  @keyframes slideUpFade {
    0% { opacity: 0; transform: translate(-50%, 20px); }
    10% { opacity: 1; transform: translate(-50%, 0); }
    90% { opacity: 1; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -20px); }
  }
</style>
