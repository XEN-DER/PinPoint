  // AI Copilot Live Analyzer Helper
  let aiAnalysisTimeout: any = null;

  function triggerLiveAIScan() {
    const description = (document.getElementById('form-description') as HTMLTextAreaElement).value;
    const title = (document.getElementById('form-title') as HTMLInputElement).value;

    const queryText = (title + ' ' + description).trim().toLowerCase();

    const copilotStatus = document.getElementById('ai-copilot-status');
    const copilotResult = document.getElementById('ai-copilot-result');
    const copilotSpinner = document.getElementById('ai-copilot-spinner');

    if (queryText.length < 5) {
      if (copilotStatus) copilotStatus.textContent = 'Awaiting Input...';
      if (copilotResult) copilotResult.textContent = 'Type a description or upload a photo to activate the live copilot suggestions.';
      if (copilotSpinner) copilotSpinner.classList.add('hidden');
      return;
    }

    if (copilotStatus) copilotStatus.textContent = 'Scanning...';
    if (copilotSpinner) copilotSpinner.classList.remove('hidden');
    if (copilotResult) {
      copilotResult.innerHTML = '<span class="text-primary italic font-medium">AI analyzing details...</span>';
    }

    if (aiAnalysisTimeout) clearTimeout(aiAnalysisTimeout);
    
    aiAnalysisTimeout = setTimeout(() => {
      let category = "Infrastructure";
      if (queryText.includes("leak") || queryText.includes("water") || queryText.includes("pipe") || queryText.includes("drain")) {
        category = "Water Leakage";
      } else if (queryText.includes("light") || queryText.includes("lamp") || queryText.includes("dark") || queryText.includes("bulb")) {
        category = "Streetlight";
      } else if (queryText.includes("trash") || queryText.includes("garbage") || queryText.includes("bin") || queryText.includes("waste")) {
        category = "Waste Management";
      }

      let severity = "Medium";
      if (queryText.includes("danger") || queryText.includes("severe") || queryText.includes("accident") || queryText.includes("flooding") || queryText.includes("injury")) {
        severity = "High";
      } else if (queryText.includes("small") || queryText.includes("minor") || queryText.includes("cosmetic")) {
        severity = "Low";
      }

      const formCategory = document.getElementById('form-category') as HTMLSelectElement;
      if (formCategory) {
        formCategory.value = category;
      }

      const radio = document.querySelector(`input[name="form-severity"][value="${severity}"]`) as HTMLInputElement;
      if (radio) {
        radio.checked = true;
        updateSeverityRadioUI();
      }

      if (copilotSpinner) copilotSpinner.classList.add('hidden');
      if (copilotStatus) copilotStatus.textContent = 'Matched ✨';
      if (copilotResult) {
        copilotResult.innerHTML = `<strong>AI Match:</strong> <span class="text-primary">${category} (${severity} Severity)</span>. Suggested parameters applied.`;
      }
    }, 1000);
  }

  // Handle severity radio pill clicks
  const severityRadios = document.querySelectorAll('input[name="form-severity"]');
  severityRadios.forEach(radio => {
    radio.addEventListener('change', () => {
