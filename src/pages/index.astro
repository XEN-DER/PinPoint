  // Render leaderboard list dynamically (Clay styled)
  function renderLeaderboard() {
    const list = document.getElementById('leaderboard-list');
    if (!list) return;
    list.innerHTML = '';

    const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
    const leaders = JSON.parse(localStorage.getItem('pinpoint_leaderboard') || '[]');

    const userIndex = leaders.findIndex((l: any) => l.isUser === true);
    if (userIndex !== -1) {
      leaders[userIndex].points = userStats.points;
      leaders[userIndex].badge = userStats.level;
    }

    leaders.sort((a: any, b: any) => b.points - a.points);
    localStorage.setItem('pinpoint_leaderboard', JSON.stringify(leaders));

    leaders.forEach((c: any, index: number) => {
      const position = index + 1;
      const highlightClass = c.isUser ? 'bg-brand-mint border-primary/20' : 'bg-canvas border-hairline';
      const medal = position === 1 ? '🥇' : position === 2 ? '🥈' : position === 3 ? '🥉' : `${position}`;

      list.innerHTML += `
        <div class="flex items-center justify-between p-3.5 rounded-md transition-colors border ${highlightClass}">
          <div class="flex items-center gap-4">
            <span class="w-6 text-center text-sm font-bold font-sans">${medal}</span>
            <div>
              <div class="text-caption font-bold text-ink">${c.name}</div>
              <div class="text-[11px] text-muted font-medium">${c.badge}</div>
            </div>
          </div>
          <div class="text-right font-sans text-sm font-bold text-ink">
            ${c.points} <span class="text-[10px] text-muted font-normal">pts</span>
          </div>
        </div>
      `;
    });
  }

  // Toast notifier
  function showToast(message: string) {
    const toast = document.getElementById('toast-notification');
    const toastMsg = document.getElementById('toast-message');
    if (toast && toastMsg) {
      toastMsg.textContent = message;
      toast.classList.remove('hidden');
      
      setTimeout(() => {
        toast.classList.add('hidden');
      }, 3000);
    }
  }

  // Render Issues Feed in Clay's Saturated Card system
  function renderFeed() {
    if (!issuesFeed || !emptyState) return;
    issuesFeed.innerHTML = '';

    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const upvoted = JSON.parse(localStorage.getItem('pinpoint_user_upvotes') || '[]');

    const query = searchInput?.value.toLowerCase() || '';
    const cat = categoryFilter?.value || 'All';
    const status = statusFilter?.value || 'All';

    const filtered = issues.filter((issue: any) => {
      const matchQuery = issue.title.toLowerCase().includes(query) || 
                          issue.description.toLowerCase().includes(query) || 
                          issue.locality.toLowerCase().includes(query);
      const matchCat = cat === 'All' ? true : issue.category === cat;
      const matchStatus = status === 'All' ? true : issue.status === status;
      const matchLocality = currentLocalityFilter === 'All' ? true : issue.locality === currentLocalityFilter;

      return matchQuery && matchCat && matchStatus && matchLocality;
    });

    if (filtered.length === 0) {
      emptyState.classList.remove('hidden');
      emptyState.classList.add('flex');
    } else {
      emptyState.classList.add('hidden');
      emptyState.classList.remove('flex');
    }

    filtered.forEach((issue: any) => {
      // 1. Map Saturated Card background colors by Category (Clay spec)
      let cardBgClass = 'bg-surface-card text-ink border-hairline';
      let textLight = false;
      
      let severityBadgeColor = 'text-red-700 bg-red-100/50 border-red-300';
      let statusBadgeColor = 'text-amber-700 bg-amber-100/50 border-amber-300 border';

      if (issue.category === 'Infrastructure') {
        cardBgClass = 'bg-brand-peach text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Streetlight') {
        cardBgClass = 'bg-brand-ochre text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Water Leakage') {
        cardBgClass = 'bg-brand-lavender text-ink border-transparent';
        severityBadgeColor = 'bg-canvas/50 text-ink border-transparent';
        statusBadgeColor = 'bg-canvas/50 text-ink border-transparent';
      } else if (issue.category === 'Waste Management') {
        cardBgClass = 'bg-brand-teal text-on-dark border-transparent';
        severityBadgeColor = 'bg-canvas/15 text-on-dark border-transparent';
        statusBadgeColor = 'bg-canvas/15 text-on-dark border-transparent';
        textLight = true;
      }

      if (issue.disputed) {
        statusBadgeColor = textLight
          ? 'bg-red-500/25 text-white border-transparent animate-pulse'
          : 'bg-red-50 text-red-700 border-red-200 border animate-pulse';
      } else if (issue.status === 'Resolved') {
        statusBadgeColor = textLight 
          ? 'bg-canvas/20 text-on-dark border-transparent' 
          : 'bg-success/20 text-success border-success/30 border';
      }

      let disputeBtnClass = '';
      if (textLight) {
        disputeBtnClass = 'bg-red-500/25 hover:bg-red-500/40 text-white border border-red-500/30';
      } else {
        disputeBtnClass = 'bg-red-50 hover:bg-red-100 text-red-600 border border-red-200';
      }

      const hasUpvoted = upvoted.includes(issue.id);
      const verifyText = issue.status === 'Open' ? `Verify (${issue.verifications})` : `Verified (${issue.verifications})`;
      
      // Secondary buttons over saturated backgrounds must be high-contrast white containers
      let upvoteBtnClass = '';
      let verifyBtnClass = '';
      let resolveBtnClass = '';

      if (textLight) {
        // Over dark teal card
        upvoteBtnClass = hasUpvoted 
          ? 'bg-canvas/30 text-on-dark border border-canvas/25' 
          : 'bg-canvas text-ink hover:bg-surface-card';
        verifyBtnClass = 'bg-canvas/20 hover:bg-canvas/30 text-on-dark border border-canvas/25';
        resolveBtnClass = 'bg-canvas text-ink hover:bg-surface-card';
      } else {
        // Over peach, lavender, ochre, or cream card
        upvoteBtnClass = hasUpvoted 
          ? 'bg-primary text-on-primary hover:bg-primary-active' 
          : 'bg-canvas text-ink hover:bg-surface-card border border-hairline';
        verifyBtnClass = 'bg-canvas hover:bg-surface-card text-ink border border-hairline';
        resolveBtnClass = 'bg-primary text-on-primary hover:bg-primary-active';
      }

      const upvoteBtnText = hasUpvoted ? 'Upvoted' : 'Upvote';

      let imageElement = '';
      if (issue.status === 'Resolved') {
        const originalImg = issue.imageUrl || '/images/pothole_vadodara.png';
        const resolvedImg = issue.resolvedImageUrl || '/images/pothole_fixed_vadodara.png';
        imageElement = `
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <div class="relative">
              <img src="${originalImg}" alt="Before - ${issue.title}" class="w-full h-48 object-cover rounded-md border border-hairline/20 shadow-product hover:opacity-95 transition-opacity" />
              <span class="absolute top-2 left-2 bg-black/75 text-white text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded shadow">BEFORE (Reported)</span>
            </div>
            <div class="relative">
              <img src="${resolvedImg}" alt="After - ${issue.title}" class="w-full h-48 object-cover rounded-md border border-hairline/20 shadow-product hover:opacity-95 transition-opacity border-success/30" />
              <span class="absolute top-2 left-2 bg-success text-white text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded shadow">AFTER (Resolved)</span>
            </div>
          </div>
        `;
      } else {
        imageElement = issue.imageUrl 
          ? `<img src="${issue.imageUrl}" alt="${issue.title}" class="w-full h-48 object-cover rounded-md border border-hairline/20 shadow-product mb-5 hover:opacity-95 transition-opacity" />`
          : '';
      }

      let auditPanel = '';
      if (issue.status === 'Resolved') {
        const resolvedBy = issue.resolvedBy || 'VMC Waste Management';
        const resolvedDate = issue.resolvedDate || '2026-06-19';
        const resolvedNotes = issue.resolvedNotes || 'Municipal waste team cleared the bins and swept the area clean.';
        
        auditPanel = `
          <div class="bg-canvas/60 border border-hairline rounded-md p-3.5 mb-4 text-xs">
            <div class="flex items-center gap-2 text-ink font-bold mb-1">
              <span class="text-success text-sm">✓</span>
              <span>Resolution Verified</span>
            </div>
            <div class="text-muted leading-relaxed font-normal mb-1.5">
              "${resolvedNotes}"
            </div>
            <div class="text-[10px] text-muted uppercase tracking-wider font-mono font-bold">
              By: ${resolvedBy} · Date: ${resolvedDate}
            </div>
          </div>
        `;
      }

      issuesFeed.innerHTML += `
        <div 
          class="border p-6 rounded-xl select-text transition-all duration-200 ${cardBgClass}" 
          id="feed-card-${issue.id}"
          data-id="${issue.id}"
        >
          <!-- Photo resting on surface with shadow -->
          ${imageElement}

          <!-- Header info -->
          <div class="flex items-center justify-between gap-4 mb-3 text-caption font-bold">
            <span class="${textLight ? 'text-on-dark-soft' : 'text-muted'}">${issue.category} · ${issue.locality}</span>
            <span class="${textLight ? 'text-on-dark-soft' : 'text-muted'} font-mono">${issue.date}</span>
          </div>

          <!-- Title -->
          <h3 class="text-title-md font-bold mb-2.5 leading-snug">
            ${issue.title}
          </h3>

          <!-- Description -->
          <p class="text-sm leading-relaxed mb-6 ${textLight ? 'text-on-dark-soft' : 'text-body'}">
            ${issue.description}
          </p>

          <!-- Audit Log Panel (Resolved state verification proof) -->
          ${auditPanel}

          <!-- Badges & Controls Row -->
          <div class="flex flex-wrap items-center gap-3 border-t border-divider-soft pt-4 mt-4">
            <!-- Severity Badge -->
            <span class="text-[11px] font-bold px-3 py-1 rounded-pill ${severityBadgeColor}">
              ${issue.severity} Severity
            </span>

            <!-- Status Badge -->
            <span class="text-[11px] font-bold px-3 py-1 rounded-pill ${statusBadgeColor}">
              ${issue.disputed ? '⚠️ Disputed' : issue.status}
            </span>

            <!-- SLA Countdown Badge -->
            ${getSLATimerHtml(issue, textLight)}

            <span class="text-xs ${textLight ? 'text-on-dark-soft' : 'text-muted'} ml-1 font-medium">By ${issue.reportedBy}</span>

            <!-- Controls (Verify, Upvote, Resolve) -->
            <div class="flex items-center gap-2 ml-auto">
              <!-- Upvote -->
              <button 
                onclick="handleUpvote('${issue.id}')"
                class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${upvoteBtnClass}"
              >
                ${upvoteBtnText} (${issue.verifications})
              </button>

              <!-- Verify (Only for Open issues) -->
              ${issue.status === 'Open' ? `
                <button 
                  onclick="handleVerify('${issue.id}')"
                  class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${verifyBtnClass}"
                >
                  Verify
                </button>
              ` : ''}

              <!-- Dispute Fix (Only for Resolved issues that are not already disputed) -->
              ${issue.status === 'Resolved' && !issue.disputed ? `
                <button 
                  onclick="handleDispute('${issue.id}')"
                  class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${disputeBtnClass}"
                >
                  Dispute Fix
                </button>
              ` : ''}

              <!-- Simulated Authority: Mark as Resolved -->
              ${issue.status !== 'Resolved' ? `
                <button 
                  onclick="handleResolve('${issue.id}')"
                  class="px-4 py-2 rounded-md text-xs font-bold active-scale cursor-pointer transition-colors ${resolveBtnClass}"
                >
                  Resolve
                </button>
              ` : ''}
            </div>
          </div>
        </div>
      `;
    });

    // Add card click listeners for map focusing
    const cards = document.querySelectorAll('[id^="feed-card-"]');
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const id = card.getAttribute('data-id');
        window.dispatchEvent(new CustomEvent('pinpoint_highlight_pin', {
          detail: { id }
        }));
      });
    });
  }

  // Upvote Action Handler
  (window as any).handleUpvote = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const upvoted = JSON.parse(localStorage.getItem('pinpoint_user_upvotes') || '[]');
    
    if (upvoted.includes(id)) {
      const index = upvoted.indexOf(id);
      upvoted.splice(index, 1);
      
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications = Math.max(0, issue.verifications - 1);
      
      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points = Math.max(0, userStats.points - 15);
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvote removed.");
    } else {
      upvoted.push(id);
      const issue = issues.find((i: any) => i.id === id);
      if (issue) issue.verifications += 1;

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
      localStorage.setItem('pinpoint_user_upvotes', JSON.stringify(upvoted));
      
      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      showToast("Upvoted issue. +15 Civic points!");
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

  // Verify Action Handler
  (window as any).handleVerify = function(id: string) {
    const issues = JSON.parse(localStorage.getItem('pinpoint_issues') || '[]');
    const issue = issues.find((i: any) => i.id === id);
    if (issue) {
      issue.verifications += 1;
      
      if (issue.verifications >= 3 && issue.status === 'Open') {
        issue.status = 'In Progress';
        showToast("Crowd verification complete. Escalated to 'In Progress'!");
      } else {
        showToast("Verification logged. +15 Civic points!");
      }

      const userStats = JSON.parse(localStorage.getItem('pinpoint_user_stats') || '{"points": 350, "level": "Civic Scout"}');
      userStats.points += 15;
      localStorage.setItem('pinpoint_user_stats', JSON.stringify(userStats));

      localStorage.setItem('pinpoint_issues', JSON.stringify(issues));
    }

    renderFeed();
    updateStatsWidgets();
    window.dispatchEvent(new CustomEvent('pinpoint_issues_updated'));
  };

